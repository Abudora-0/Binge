<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Binge — Reports</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
</head>
<body class="bg-gray-950 text-white min-h-screen">

  <nav class="bg-gray-900 border-b border-gray-800 px-6 py-3 flex items-center justify-between sticky top-0 z-50">
    <div class="flex items-center gap-2">
      <i data-lucide="bar-chart-2" class="w-5 h-5 text-red-500"></i>
      <h1 class="text-xl font-bold text-red-500">Binge <span class="text-gray-400 text-sm font-normal ml-1">Reports</span></h1>
    </div>
    <div class="flex items-center gap-4">
      <a href="/admin/dashboard" class="flex items-center gap-2 text-gray-400 hover:text-white text-sm transition">
        <i data-lucide="arrow-left" class="w-4 h-4"></i> Admin Panel
      </a>
      <a href="/auth/logout" class="flex items-center gap-2 text-red-400 hover:text-red-300 text-sm transition">
        <i data-lucide="log-out" class="w-4 h-4"></i> Sign Out
      </a>
    </div>
  </nav>

  <div class="max-w-5xl mx-auto px-6 py-10">
    <div class="mb-8">
      <h2 class="text-2xl font-bold flex items-center gap-3">
        <i data-lucide="file-text" class="w-7 h-7 text-red-500"></i>
        PDF Business Reports
      </h2>
      <p class="text-gray-400 text-sm mt-1">Select a report, apply filters and generate PDF</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">

      <!-- Report 1: Trending Videos -->
      <div class="bg-gray-900 border border-gray-700 hover:border-red-500 rounded-xl p-5 transition">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 bg-red-600/20 rounded-lg flex items-center justify-center">
            <i data-lucide="trending-up" class="w-5 h-5 text-red-400"></i>
          </div>
          <div>
            <h3 class="font-bold text-sm">Trending Videos</h3>
            <p class="text-gray-400 text-xs">Top videos by views, likes and comments</p>
          </div>
        </div>
        <form action="/reports/trending" method="GET" target="_blank" class="space-y-2">
          <select name="categoryId" class="w-full bg-gray-800 text-white border border-gray-700 rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-red-500">
            <option value="">All Categories</option>
            <% categories.forEach(c => { %><option value="<%= c.Id %>"><%= c.Name %></option><% }) %>
          </select>
          <div class="flex gap-2">
            <input type="date" name="from" class="flex-1 bg-gray-800 text-white border border-gray-700 rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-red-500">
            <input type="date" name="to"   class="flex-1 bg-gray-800 text-white border border-gray-700 rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-red-500">
          </div>
          <button type="submit" class="w-full flex items-center justify-center gap-2 bg-red-600 hover:bg-red-700 text-white text-xs py-2 rounded-lg transition">
            <i data-lucide="download" class="w-3 h-3"></i> Generate PDF
          </button>
        </form>
      </div>

      <!-- Report 2: Top Creators -->
      <div class="bg-gray-900 border border-gray-700 hover:border-red-500 rounded-xl p-5 transition">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 bg-blue-600/20 rounded-lg flex items-center justify-center">
            <i data-lucide="award" class="w-5 h-5 text-blue-400"></i>
          </div>
          <div>
            <h3 class="font-bold text-sm">Top Creators</h3>
            <p class="text-gray-400 text-xs">Most subscribed creators on the platform</p>
          </div>
        </div>
        <form action="/reports/creators" method="GET" target="_blank" class="space-y-2">
          <select name="country" class="w-full bg-gray-800 text-white border border-gray-700 rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-red-500">
            <option value="">All Countries</option>
            <option value="Pakistan">Pakistan</option>
            <option value="India">India</option>
            <option value="USA">USA</option>
            <option value="UK">UK</option>
            <option value="UAE">UAE</option>
          </select>
          <button type="submit" class="w-full flex items-center justify-center gap-2 bg-red-600 hover:bg-red-700 text-white text-xs py-2 rounded-lg transition">
            <i data-lucide="download" class="w-3 h-3"></i> Generate PDF
          </button>
        </form>
      </div>

      <!-- Report 3: Category Engagement -->
      <div class="bg-gray-900 border border-gray-700 hover:border-red-500 rounded-xl p-5 transition">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 bg-purple-600/20 rounded-lg flex items-center justify-center">
            <i data-lucide="pie-chart" class="w-5 h-5 text-purple-400"></i>
          </div>
          <div>
            <h3 class="font-bold text-sm">Category Engagement</h3>
            <p class="text-gray-400 text-xs">Views and likes broken down by category</p>
          </div>
        </div>
        <form action="/reports/categories" method="GET" target="_blank" class="space-y-2">
          <div class="flex gap-2">
            <input type="date" name="from" class="flex-1 bg-gray-800 text-white border border-gray-700 rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-red-500">
            <input type="date" name="to"   class="flex-1 bg-gray-800 text-white border border-gray-700 rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-red-500">
          </div>
          <button type="submit" class="w-full flex items-center justify-center gap-2 bg-red-600 hover:bg-red-700 text-white text-xs py-2 rounded-lg transition">
            <i data-lucide="download" class="w-3 h-3"></i> Generate PDF
          </button>
        </form>
      </div>

      <!-- Report 4: Video Engagement -->
      <div class="bg-gray-900 border border-gray-700 hover:border-red-500 rounded-xl p-5 transition">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 bg-green-600/20 rounded-lg flex items-center justify-center">
            <i data-lucide="activity" class="w-5 h-5 text-green-400"></i>
          </div>
          <div>
            <h3 class="font-bold text-sm">Video Engagement Score</h3>
            <p class="text-gray-400 text-xs">Engagement score per video</p>
          </div>
        </div>
        <form action="/reports/engagement" method="GET" target="_blank" class="space-y-2">
          <select name="categoryId" class="w-full bg-gray-800 text-white border border-gray-700 rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-red-500">
            <option value="">All Categories</option>
            <% categories.forEach(c => { %><option value="<%= c.Id %>"><%= c.Name %></option><% }) %>
          </select>
          <button type="submit" class="w-full flex items-center justify-center gap-2 bg-red-600 hover:bg-red-700 text-white text-xs py-2 rounded-lg transition">
            <i data-lucide="download" class="w-3 h-3"></i> Generate PDF
          </button>
        </form>
      </div>

      <!-- Report 5: Monthly Watch -->
      <div class="bg-gray-900 border border-gray-700 hover:border-red-500 rounded-xl p-5 transition">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 bg-yellow-600/20 rounded-lg flex items-center justify-center">
            <i data-lucide="calendar" class="w-5 h-5 text-yellow-400"></i>
          </div>
          <div>
            <h3 class="font-bold text-sm">Monthly Watch Summary</h3>
            <p class="text-gray-400 text-xs">Watch activity by month and year</p>
          </div>
        </div>
        <form action="/reports/monthly" method="GET" target="_blank" class="space-y-2">
          <div class="flex gap-2">
            <input type="number" name="month" min="1" max="12" placeholder="Month (1-12)"
              class="flex-1 bg-gray-800 text-white border border-gray-700 rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-red-500">
            <input type="number" name="year" min="2024" max="2030" placeholder="Year"
              class="flex-1 bg-gray-800 text-white border border-gray-700 rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-red-500">
          </div>
          <button type="submit" class="w-full flex items-center justify-center gap-2 bg-red-600 hover:bg-red-700 text-white text-xs py-2 rounded-lg transition">
            <i data-lucide="download" class="w-3 h-3"></i> Generate PDF
          </button>
        </form>
      </div>

      <!-- Report 6: All Users -->
      <div class="bg-gray-900 border border-gray-700 hover:border-red-500 rounded-xl p-5 transition">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 bg-cyan-600/20 rounded-lg flex items-center justify-center">
            <i data-lucide="users" class="w-5 h-5 text-cyan-400"></i>
          </div>
          <div>
            <h3 class="font-bold text-sm">All Users</h3>
            <p class="text-gray-400 text-xs">Complete list of registered users</p>
          </div>
        </div>
        <form action="/reports/users" method="GET" target="_blank" class="space-y-2">
          <select name="status" class="w-full bg-gray-800 text-white border border-gray-700 rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-red-500">
            <option value="">All Status</option>
            <option value="Active">Active</option>
            <option value="Suspended">Suspended</option>
            <option value="Banned">Banned</option>
          </select>
          <select name="country" class="w-full bg-gray-800 text-white border border-gray-700 rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-red-500">
            <option value="">All Countries</option>
            <option value="Pakistan">Pakistan</option>
            <option value="India">India</option>
            <option value="USA">USA</option>
            <option value="UK">UK</option>
            <option value="UAE">UAE</option>
          </select>
          <button type="submit" class="w-full flex items-center justify-center gap-2 bg-red-600 hover:bg-red-700 text-white text-xs py-2 rounded-lg transition">
            <i data-lucide="download" class="w-3 h-3"></i> Generate PDF
          </button>
        </form>
      </div>

      <!-- Report 7: All Videos -->
      <div class="bg-gray-900 border border-gray-700 hover:border-red-500 rounded-xl p-5 transition">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 bg-orange-600/20 rounded-lg flex items-center justify-center">
            <i data-lucide="film" class="w-5 h-5 text-orange-400"></i>
          </div>
          <div>
            <h3 class="font-bold text-sm">All Videos</h3>
            <p class="text-gray-400 text-xs">Complete video library with status</p>
          </div>
        </div>
        <form action="/reports/videos" method="GET" target="_blank" class="space-y-2">
          <select name="status" class="w-full bg-gray-800 text-white border border-gray-700 rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-red-500">
            <option value="">All Status</option>
            <option value="Published">Published</option>
            <option value="Private">Private</option>
            <option value="Unlisted">Unlisted</option>
          </select>
          <select name="categoryId" class="w-full bg-gray-800 text-white border border-gray-700 rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-red-500">
            <option value="">All Categories</option>
            <% categories.forEach(c => { %><option value="<%= c.Id %>"><%= c.Name %></option><% }) %>
          </select>
          <button type="submit" class="w-full flex items-center justify-center gap-2 bg-red-600 hover:bg-red-700 text-white text-xs py-2 rounded-lg transition">
            <i data-lucide="download" class="w-3 h-3"></i> Generate PDF
          </button>
        </form>
      </div>

      <!-- Report 8: Comment Activity -->
      <div class="bg-gray-900 border border-gray-700 hover:border-red-500 rounded-xl p-5 transition">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 bg-pink-600/20 rounded-lg flex items-center justify-center">
            <i data-lucide="message-circle" class="w-5 h-5 text-pink-400"></i>
          </div>
          <div>
            <h3 class="font-bold text-sm">Comment Activity</h3>
            <p class="text-gray-400 text-xs">Comment count per video</p>
          </div>
        </div>
        <form action="/reports/comments" method="GET" target="_blank" class="space-y-2">
          <div class="flex gap-2">
            <input type="date" name="from" class="flex-1 bg-gray-800 text-white border border-gray-700 rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-red-500">
            <input type="date" name="to"   class="flex-1 bg-gray-800 text-white border border-gray-700 rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-red-500">
          </div>
          <button type="submit" class="w-full flex items-center justify-center gap-2 bg-red-600 hover:bg-red-700 text-white text-xs py-2 rounded-lg transition">
            <i data-lucide="download" class="w-3 h-3"></i> Generate PDF
          </button>
        </form>
      </div>

      <!-- Report 9: Subscriptions -->
      <div class="bg-gray-900 border border-gray-700 hover:border-red-500 rounded-xl p-5 transition">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 bg-indigo-600/20 rounded-lg flex items-center justify-center">
            <i data-lucide="bell" class="w-5 h-5 text-indigo-400"></i>
          </div>
          <div>
            <h3 class="font-bold text-sm">Subscription Report</h3>
            <p class="text-gray-400 text-xs">Subscription counts per creator</p>
          </div>
        </div>
        <form action="/reports/subscriptions" method="GET" target="_blank" class="space-y-2">
          <div class="flex gap-2">
            <input type="date" name="from" class="flex-1 bg-gray-800 text-white border border-gray-700 rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-red-500">
            <input type="date" name="to"   class="flex-1 bg-gray-800 text-white border border-gray-700 rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-red-500">
          </div>
          <button type="submit" class="w-full flex items-center justify-center gap-2 bg-red-600 hover:bg-red-700 text-white text-xs py-2 rounded-lg transition">
            <i data-lucide="download" class="w-3 h-3"></i> Generate PDF
          </button>
        </form>
      </div>

      <!-- Report 10: Moderation -->
      <div class="bg-gray-900 border border-gray-700 hover:border-red-500 rounded-xl p-5 transition">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 bg-red-600/20 rounded-lg flex items-center justify-center">
            <i data-lucide="flag" class="w-5 h-5 text-red-400"></i>
          </div>
          <div>
            <h3 class="font-bold text-sm">Content Moderation</h3>
            <p class="text-gray-400 text-xs">Reported videos with resolution status</p>
          </div>
        </div>
        <form action="/reports/moderation" method="GET" target="_blank" class="space-y-2">
          <select name="status" class="w-full bg-gray-800 text-white border border-gray-700 rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-red-500">
            <option value="">All Status</option>
            <option value="Pending">Pending</option>
            <option value="Reviewed">Reviewed</option>
            <option value="Dismissed">Dismissed</option>
            <option value="ActionTaken">Action Taken</option>
          </select>
          <button type="submit" class="w-full flex items-center justify-center gap-2 bg-red-600 hover:bg-red-700 text-white text-xs py-2 rounded-lg transition">
            <i data-lucide="download" class="w-3 h-3"></i> Generate PDF
          </button>
        </form>
      </div>

    </div>
  </div>

  <script>lucide.createIcons();</script>
</body>
</html>