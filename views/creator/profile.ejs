<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Binge — Creator Profile</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
</head>
<body class="bg-gray-950 text-white min-h-screen flex flex-col">

  <nav class="bg-gray-950 border-b border-gray-800 px-6 py-3 flex items-center justify-between sticky top-0 z-50">
    <a href="/creator/dashboard" class="flex items-center gap-2">
      <i data-lucide="arrow-left" class="w-5 h-5 text-gray-400 hover:text-white transition"></i>
      <span class="text-xl font-bold text-red-500">Binge</span>
    </a>
    <a href="/auth/logout" class="flex items-center gap-2 text-red-400 hover:text-red-300 text-sm transition">
      <i data-lucide="log-out" class="w-4 h-4"></i> Sign Out
    </a>
  </nav>

  <!-- Banner -->
  <div class="h-40 bg-gradient-to-r from-red-900/50 via-gray-900 to-gray-950 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-4 left-10 w-32 h-32 bg-red-500 rounded-full blur-3xl"></div>
      <div class="absolute bottom-4 right-20 w-48 h-48 bg-red-700 rounded-full blur-3xl"></div>
    </div>
  </div>

  <div class="max-w-3xl mx-auto px-6 w-full -mt-16 pb-16">

    <!-- Profile Card -->
    <div class="bg-gray-900 rounded-2xl border border-gray-800 overflow-hidden shadow-2xl mb-6">

      <!-- Avatar + Info -->
      <div class="px-8 pt-6 pb-6 flex items-end gap-6">
        <div class="relative flex-shrink-0">
          <div class="w-24 h-24 rounded-full border-4 border-gray-900 overflow-hidden bg-red-600 flex items-center justify-center text-3xl font-bold shadow-xl">
            <% if (userData.Avatar) { %>
              <img src="/uploads/<%= userData.Avatar %>" class="w-full h-full object-cover" id="avatarPreview">
            <% } else { %>
              <span id="avatarInitial"><%= userData.FirstName.charAt(0).toUpperCase() %></span>
              <img id="avatarPreview" class="w-full h-full object-cover hidden">
            <% } %>
          </div>
          <label for="avatarInput"
            class="absolute bottom-0 right-0 w-7 h-7 bg-red-600 hover:bg-red-700 rounded-full flex items-center justify-center cursor-pointer transition shadow-lg border-2 border-gray-900">
            <i data-lucide="camera" class="w-3.5 h-3.5 text-white"></i>
          </label>
        </div>

        <form action="/creator/profile/avatar" method="POST" enctype="multipart/form-data" id="avatarForm" class="hidden">
          <input type="file" name="avatar" id="avatarInput" accept="image/*" class="hidden">
        </form>

        <div class="flex-1 pb-1">
          <h2 class="text-2xl font-bold"><%= userData.FirstName %> <%= userData.LastName %></h2>
          <p class="text-red-400 text-sm font-medium"><%= creatorData.ChannelName %></p>
          <p class="text-gray-400 text-sm flex items-center gap-1.5 mt-1">
            <i data-lucide="mail" class="w-3.5 h-3.5"></i> <%= userData.Email %>
          </p>
          <div class="flex items-center gap-3 mt-2">
            <span class="flex items-center gap-1.5 text-xs text-gray-400 bg-gray-800 px-3 py-1 rounded-full">
              <i data-lucide="users" class="w-3 h-3"></i> <%= creatorData.TotalSubscribers.toLocaleString() %> subscribers
            </span>
            <span class="flex items-center gap-1.5 text-xs text-gray-400 bg-gray-800 px-3 py-1 rounded-full">
              <i data-lucide="globe" class="w-3 h-3"></i> <%= userData.Country %>
            </span>
          </div>
        </div>
      </div>

      <!-- Alerts -->
      <% if (typeof success !== 'undefined' && success) { %>
        <div class="mx-8 mb-4 flex items-center gap-2 bg-green-500/20 border border-green-500/50 text-green-400 px-4 py-3 rounded-xl text-sm">
          <i data-lucide="check-circle" class="w-4 h-4"></i> <%= success %>
        </div>
      <% } %>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="mx-8 mb-4 flex items-center gap-2 bg-red-500/20 border border-red-500/50 text-red-400 px-4 py-3 rounded-xl text-sm">
          <i data-lucide="alert-circle" class="w-4 h-4"></i> <%= error %>
        </div>
      <% } %>

      <div class="border-t border-gray-800 mx-8"></div>

      <!-- Edit Forms -->
      <div class="px-8 py-6 space-y-8">

        <!-- Personal Info -->
        <div>
          <h3 class="font-semibold text-base mb-4 flex items-center gap-2 text-gray-200">
            <i data-lucide="user" class="w-4 h-4 text-red-400"></i> Personal Info
          </h3>
          <form action="/creator/profile/update" method="POST" class="space-y-4">
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-gray-400 text-xs mb-1.5 uppercase tracking-wider">First Name</label>
                <input type="text" name="firstName" value="<%= userData.FirstName %>" required
                  class="w-full bg-gray-800 text-white border border-gray-700 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-red-500 transition">
              </div>
              <div>
                <label class="block text-gray-400 text-xs mb-1.5 uppercase tracking-wider">Last Name</label>
                <input type="text" name="lastName" value="<%= userData.LastName %>" required
                  class="w-full bg-gray-800 text-white border border-gray-700 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-red-500 transition">
              </div>
            </div>
            <div>
              <label class="block text-gray-400 text-xs mb-1.5 uppercase tracking-wider">Country</label>
              <select name="country"
                class="w-full bg-gray-800 text-white border border-gray-700 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-red-500 transition">
                <% ['Pakistan','India','USA','UK','Canada','Australia','UAE','Saudi Arabia','Other'].forEach(c => { %>
                  <option value="<%= c %>" <%= userData.Country === c ? 'selected' : '' %>><%= c %></option>
                <% }) %>
              </select>
            </div>
            <button type="submit"
              class="flex items-center gap-2 bg-red-600 hover:bg-red-700 text-white text-sm px-5 py-2.5 rounded-xl transition">
              <i data-lucide="save" class="w-4 h-4"></i> Save Changes
            </button>
          </form>
        </div>

        <div class="border-t border-gray-800"></div>

        <!-- Channel Info -->
        <div>
          <h3 class="font-semibold text-base mb-4 flex items-center gap-2 text-gray-200">
            <i data-lucide="tv-2" class="w-4 h-4 text-red-400"></i> Channel Info
          </h3>
          <form action="/creator/profile/channel" method="POST" class="space-y-4">
            <div>
              <label class="block text-gray-400 text-xs mb-1.5 uppercase tracking-wider">Channel Name</label>
              <input type="text" name="channelName" value="<%= creatorData.ChannelName %>" required
                class="w-full bg-gray-800 text-white border border-gray-700 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-red-500 transition">
            </div>
            <div>
              <label class="block text-gray-400 text-xs mb-1.5 uppercase tracking-wider">Bio</label>
              <textarea name="bio" rows="3" placeholder="Tell viewers about your channel..."
                class="w-full bg-gray-800 text-white border border-gray-700 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-red-500 transition resize-none"><%= creatorData.Bio || '' %></textarea>
            </div>
            <button type="submit"
              class="flex items-center gap-2 bg-red-600 hover:bg-red-700 text-white text-sm px-5 py-2.5 rounded-xl transition">
              <i data-lucide="save" class="w-4 h-4"></i> Update Channel
            </button>
          </form>
        </div>

      </div>
    </div>

    <!-- Quick Links -->
    <div class="grid grid-cols-3 gap-4">
      <a href="/creator/dashboard" class="bg-gray-900 hover:bg-gray-800 border border-gray-800 hover:border-red-500 rounded-2xl p-5 flex flex-col items-center gap-2 transition group">
        <i data-lucide="layout-dashboard" class="w-6 h-6 text-gray-400 group-hover:text-red-400 transition"></i>
        <span class="text-sm text-gray-300">Dashboard</span>
      </a>
      <a href="/creator/upload" class="bg-gray-900 hover:bg-gray-800 border border-gray-800 hover:border-red-500 rounded-2xl p-5 flex flex-col items-center gap-2 transition group">
        <i data-lucide="upload" class="w-6 h-6 text-gray-400 group-hover:text-red-400 transition"></i>
        <span class="text-sm text-gray-300">Upload Video</span>
      </a>
      <a href="/viewer/home" class="bg-gray-900 hover:bg-gray-800 border border-gray-800 hover:border-red-500 rounded-2xl p-5 flex flex-col items-center gap-2 transition group">
        <i data-lucide="tv-2" class="w-6 h-6 text-gray-400 group-hover:text-red-400 transition"></i>
        <span class="text-sm text-gray-300">View as Viewer</span>
      </a>
    </div>

  </div>

  <script>
    lucide.createIcons();

    document.getElementById('avatarInput').addEventListener('change', function() {
      if (this.files && this.files[0]) {
        const reader = new FileReader();
        reader.onload = e => {
          const preview = document.getElementById('avatarPreview');
          const initial = document.getElementById('avatarInitial');
          preview.src = e.target.result;
          preview.classList.remove('hidden');
          if (initial) initial.classList.add('hidden');
        };
        reader.readAsDataURL(this.files[0]);
        document.getElementById('avatarForm').submit();
      }
    });
  </script>
</body>
</html>