<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Binge — Upload Video</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
</head>
<body class="bg-gray-950 text-white min-h-screen">

  <!-- Navbar -->
  <nav class="bg-gray-950 border-b border-gray-800 px-6 py-3 flex items-center justify-between sticky top-0 z-50">
    <div class="flex items-center gap-3">
      <i data-lucide="video" class="w-5 h-5 text-red-500"></i>
      <h1 class="text-xl font-bold text-red-500">Binge <span class="text-gray-400 text-sm font-normal ml-1">Upload</span></h1>
    </div>
    <div class="flex items-center gap-3">
      <a href="/creator/dashboard" class="flex items-center gap-2 text-gray-400 hover:text-white text-sm transition">
        <i data-lucide="arrow-left" class="w-4 h-4"></i> Dashboard
      </a>
      <a href="/auth/logout" class="flex items-center gap-2 bg-red-600 hover:bg-red-700 text-white text-sm px-4 py-2 rounded-lg transition">
        <i data-lucide="log-out" class="w-4 h-4"></i> Logout
      </a>
    </div>
  </nav>

  <div class="max-w-3xl mx-auto px-6 py-10">

    <div class="flex items-center gap-3 mb-2">
      <div class="w-10 h-10 bg-red-600/20 rounded-xl flex items-center justify-center">
        <i data-lucide="<%= isEdit ? 'edit-3' : 'upload-cloud' %>" class="w-5 h-5 text-red-400"></i>
      </div>
      <h2 class="text-2xl font-bold"><%= isEdit ? 'Edit Video' : 'Upload New Video' %></h2>
    </div>
    <p class="text-gray-400 text-sm mb-8"><%= isEdit ? 'Update your video details below' : 'Fill in the details below to publish your video' %></p>

    <!-- Error -->
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="flex items-center gap-2 bg-red-500/20 border border-red-500/50 text-red-400 px-4 py-3 rounded-xl mb-6 text-sm">
        <i data-lucide="alert-circle" class="w-4 h-4 flex-shrink-0"></i>
        <%= error %>
      </div>
    <% } %>

    <form action="<%= isEdit ? '/creator/video/edit/' + video.Id : '/creator/upload' %>" method="POST" class="space-y-6">

      <!-- Title -->
      <div>
        <label class="block text-gray-400 text-xs uppercase tracking-wider mb-2">Video Title <span class="text-red-500">*</span></label>
        <div class="relative">
          <i data-lucide="heading-2" class="w-4 h-4 absolute left-3.5 top-3 text-gray-500"></i>
          <input
            type="text"
            name="title"
            required
            maxlength="200"
            placeholder="Enter a catchy title"
            value="<%= isEdit ? video.Title : '' %>"
            class="w-full bg-gray-800 text-white border border-gray-700 rounded-xl pl-10 pr-4 py-2.5 text-sm focus:outline-none focus:border-red-500 transition"
          />
        </div>
      </div>

      <!-- Description -->
      <div>
        <label class="block text-gray-400 text-xs uppercase tracking-wider mb-2">Description</label>
        <textarea
          name="description"
          rows="4"
          placeholder="Tell viewers about your video..."
          class="w-full bg-gray-800 text-white border border-gray-700 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-red-500 transition resize-none"
        ><%= isEdit ? video.Description : '' %></textarea>
      </div>

      <!-- Video URL -->
      <div>
        <label class="block text-gray-400 text-xs uppercase tracking-wider mb-2">Video URL <span class="text-red-500">*</span></label>
        <div class="relative">
          <i data-lucide="link" class="w-4 h-4 absolute left-3.5 top-3 text-gray-500"></i>
          <input
            type="url"
            name="videoUrl"
            required
            placeholder="https://www.youtube.com/watch?v=..."
            value="<%= isEdit ? video.VideoUrl : '' %>"
            class="w-full bg-gray-800 text-white border border-gray-700 rounded-xl pl-10 pr-4 py-2.5 text-sm focus:outline-none focus:border-red-500 transition"
          />
        </div>
        <p class="text-gray-500 text-xs mt-1.5"><i data-lucide="info" class="w-3 h-3 inline mr-1"></i>Paste a YouTube or any video URL</p>
      </div>

      <!-- Duration & Category row -->
      <div class="grid grid-cols-2 gap-4">

        <!-- Duration -->
        <div>
          <label class="block text-gray-400 text-xs uppercase tracking-wider mb-2">Duration (seconds) <span class="text-red-500">*</span></label>
          <div class="relative">
            <i data-lucide="clock" class="w-4 h-4 absolute left-3.5 top-3 text-gray-500"></i>
            <input
              type="number"
              name="duration"
              required
              min="1"
              placeholder="e.g. 600"
              value="<%= isEdit ? video.Duration : '' %>"
              class="w-full bg-gray-800 text-white border border-gray-700 rounded-xl pl-10 pr-4 py-2.5 text-sm focus:outline-none focus:border-red-500 transition"
            />
          </div>
        </div>

        <!-- Category -->
        <div>
          <label class="block text-gray-400 text-xs uppercase tracking-wider mb-2">Category <span class="text-red-500">*</span></label>
          <div class="relative">
            <i data-lucide="layers" class="w-4 h-4 absolute left-3.5 top-3 text-gray-500"></i>
            <select
              name="categoryId"
              required
              class="w-full bg-gray-800 text-white border border-gray-700 rounded-xl pl-10 pr-4 py-2.5 text-sm focus:outline-none focus:border-red-500 transition appearance-none"
            >
            <option value="">Select a category</option>
              <option value="">Select a category</option>
              <% categories.forEach(cat => { %>
                <option value="<%= cat.Id %>" <%= isEdit && video.CategoryId === cat.Id ? 'selected' : '' %>>
                  <%= cat.Name %>
                </option>
              <% }) %>
            </select>
          </div>
        </div>

      </div>

      <!-- Visibility -->
      <div>
        <label class="block text-gray-400 text-xs uppercase tracking-wider mb-3">Visibility</label>
        <div class="grid grid-cols-3 gap-3">
          <label class="flex items-center gap-3 bg-gray-800 hover:bg-gray-700 p-3 rounded-xl border border-gray-700 cursor-pointer transition">
            <input type="radio" name="status" value="Published"
              <%= !isEdit || video.Status === 'Published' ? 'checked' : '' %>
              class="accent-red-500">
            <div class="flex items-center gap-2">
              <i data-lucide="globe" class="w-4 h-4 text-gray-400"></i>
              <span class="text-sm text-gray-300">Published</span>
            </div>
          </label>
          <label class="flex items-center gap-3 bg-gray-800 hover:bg-gray-700 p-3 rounded-xl border border-gray-700 cursor-pointer transition">
            <input type="radio" name="status" value="Private"
              <%= isEdit && video.Status === 'Private' ? 'checked' : '' %>
              class="accent-red-500">
            <div class="flex items-center gap-2">
              <i data-lucide="lock" class="w-4 h-4 text-gray-400"></i>
              <span class="text-sm text-gray-300">Private</span>
            </div>
          </label>
          <label class="flex items-center gap-3 bg-gray-800 hover:bg-gray-700 p-3 rounded-xl border border-gray-700 cursor-pointer transition">
            <input type="radio" name="status" value="Unlisted"
              <%= isEdit && video.Status === 'Unlisted' ? 'checked' : '' %>
              class="accent-red-500">
            <div class="flex items-center gap-2">
              <i data-lucide="eye-off" class="w-4 h-4 text-gray-400"></i>
              <span class="text-sm text-gray-300">Unlisted</span>
            </div>
          </label>
        </div>
      </div>

      <!-- Tags -->
      <div>
        <label class="block text-gray-400 text-xs uppercase tracking-wider mb-3">Tags</label>
        <div class="flex flex-wrap gap-3">
          <% tags.forEach(tag => { %>
            <label class="flex items-center gap-2 text-gray-300 text-sm cursor-pointer bg-gray-800 hover:bg-gray-700 px-3 py-1.5 rounded-full border border-gray-700 hover:border-red-500/50 transition">
              <input type="checkbox" name="tags" value="<%= tag.Id %>"
                <%= isEdit && video.tags && video.tags.includes(tag.Id) ? 'checked' : '' %>
                class="accent-red-500">
              <i data-lucide="tag" class="w-3 h-3"></i>
              <%= tag.Name %>
            </label>
          <% }) %>
        </div>
      </div>

      <!-- Submit -->
      <div class="flex gap-3 pt-2">
        <button
          type="submit"
          class="flex items-center justify-center gap-2 flex-1 bg-red-600 hover:bg-red-700 text-white font-semibold py-3 rounded-xl transition">
          <i data-lucide="<%= isEdit ? 'check' : 'upload' %>" class="w-4 h-4"></i>
          <%= isEdit ? 'Save Changes' : 'Upload Video' %>
        </button>
        <a href="/creator/dashboard"
           class="flex items-center justify-center gap-2 flex-1 bg-gray-800 hover:bg-gray-700 text-gray-300 font-semibold py-3 rounded-xl transition">
          <i data-lucide="x" class="w-4 h-4"></i>
          Cancel
        </a>
      </div>

    </form>
  </div>

  <script>lucide.createIcons();</script>
</body>
</html>