<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Binge — Sign In</title>
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="shortcut icon" href="/favicon.ico">
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
  <link rel="stylesheet" href="/binge.css">
</head>
<body class="bg-gray-950 min-h-screen flex">

  <!-- Left Panel -->
  <div class="hidden lg:flex w-1/2 bg-gradient-to-br from-red-900/40 via-gray-900 to-gray-950 flex-col items-center justify-center p-12 relative overflow-hidden">
    <div class="absolute inset-0 opacity-5">
      <div class="grid grid-cols-8 gap-2 h-full">
        <% for(let i=0; i<64; i++) { %>
          <div class="bg-red-500 rounded"></div>
        <% } %>
      </div>
    </div>
    <div class="relative z-10 text-center">
      <img src="/logo.png" alt="Binge" class="h-16 w-auto mx-auto mb-4"
           onerror="this.onerror=null;this.src='/logo.svg'">
      <p class="text-gray-300 text-xl mb-2">Watch. Create. Connect.</p>
      <p class="text-gray-500 text-sm max-w-xs">Join millions of viewers and creators on Pakistan's fastest growing video platform.</p>
      <div class="flex justify-center gap-8 mt-10">
        <div class="text-center">
          <p class="text-2xl font-bold text-white">70+</p>
          <p class="text-gray-400 text-xs">Videos</p>
        </div>
        <div class="text-center">
          <p class="text-2xl font-bold text-white">14</p>
          <p class="text-gray-400 text-xs">Creators</p>
        </div>
        <div class="text-center">
          <p class="text-2xl font-bold text-white">7</p>
          <p class="text-gray-400 text-xs">Categories</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Right Panel -->
  <div class="flex-1 flex items-center justify-center p-6 bg-gray-950">
    <div class="w-full max-w-md">

      <!-- Logo for mobile -->
      <div class="lg:hidden text-center mb-8">
        <img src="/logo.png" alt="Binge" class="h-10 w-auto mx-auto"
             onerror="this.onerror=null;this.src='/logo.svg'">
      </div>

      <div class="bg-gray-900 rounded-2xl p-8 shadow-2xl border border-gray-800">

        <h2 class="text-2xl text-red-500 font-bold mb-1">Welcome back</h2>
        <p class="text-gray-400 text-sm mb-6">Sign in to continue watching</p>

        <!-- Login error -->
        <% if (typeof error !== 'undefined' && error) { %>
          <div class="flex items-center gap-2 bg-red-500/20 border border-red-500/50 text-red-400 px-4 py-3 rounded-xl mb-5 text-sm">
            <i data-lucide="alert-circle" class="w-4 h-4 flex-shrink-0"></i>
            <%= error %>
          </div>
        <% } %>

        <!-- Reset success -->
        <% if (typeof resetSuccess !== 'undefined' && resetSuccess) { %>
          <div class="flex items-center gap-2 bg-green-500/20 border border-green-500/50 text-green-400 px-4 py-3 rounded-xl mb-5 text-sm">
            <i data-lucide="check-circle" class="w-4 h-4 flex-shrink-0"></i>
            <%= resetSuccess %>
          </div>
        <% } %>

        <form action="/auth/login" method="POST" class="space-y-4">

          <!-- Email -->
          <div>
            <label class="block text-gray-400 text-sm mb-1.5">Email Address</label>
            <div class="relative">
              <i data-lucide="mail" class="w-4 h-4 absolute left-3.5 top-3 text-gray-500"></i>
              <input type="email" name="email" required placeholder="you@example.com"
                class="w-full bg-gray-800 text-white border border-gray-700 rounded-xl pl-10 pr-4 py-2.5 text-sm focus:outline-none focus:border-red-500 transition"/>
            </div>
          </div>

          <!-- Password -->
          <div>
            <div class="flex items-center justify-between mb-1.5">
              <label class="text-gray-400 text-sm">Password</label>
              <button type="button" onclick="openForgotModal()"
                class="text-red-400 hover:text-red-300 text-xs transition font-medium">
                Forgot password?
              </button>
            </div>
            <div class="relative">
              <i data-lucide="lock" class="w-4 h-4 absolute left-3.5 top-3 text-gray-500"></i>
              <input type="password" name="password" id="loginPassword" required placeholder="••••••••"
                class="w-full bg-gray-800 text-white border border-gray-700 rounded-xl pl-10 pr-11 py-2.5 text-sm focus:outline-none focus:border-red-500 transition"/>
              <button type="button" onclick="togglePassword('loginPassword', 'loginEye')"
                class="absolute right-3.5 top-3 text-gray-500 hover:text-gray-300 transition">
                <i data-lucide="eye" id="loginEye" class="w-4 h-4"></i>
              </button>
            </div>
          </div>

          <!-- Login As -->
          <div>
            <label class="block text-gray-400 text-sm mb-2">Login As</label>
            <div class="grid grid-cols-3 gap-2">
              <label class="cursor-pointer">
                <input type="radio" name="role" value="viewer" checked class="peer hidden">
                <div class="flex flex-col items-center gap-1 px-3 py-2.5 rounded-xl border border-gray-700 peer-checked:border-red-500 peer-checked:bg-red-500/10 hover:border-gray-500 transition text-center">
                  <i data-lucide="user" class="w-4 h-4 text-gray-400 peer-checked:text-red-400"></i>
                  <span class="text-xs text-gray-400">Viewer</span>
                </div>
              </label>
              <label class="cursor-pointer">
                <input type="radio" name="role" value="creator" class="peer hidden">
                <div class="flex flex-col items-center gap-1 px-3 py-2.5 rounded-xl border border-gray-700 peer-checked:border-red-500 peer-checked:bg-red-500/10 hover:border-gray-500 transition text-center">
                  <i data-lucide="video" class="w-4 h-4 text-gray-400"></i>
                  <span class="text-xs text-gray-400">Creator</span>
                </div>
              </label>
              <label class="cursor-pointer">
                <input type="radio" name="role" value="admin" class="peer hidden">
                <div class="flex flex-col items-center gap-1 px-3 py-2.5 rounded-xl border border-gray-700 peer-checked:border-red-500 peer-checked:bg-red-500/10 hover:border-gray-500 transition text-center">
                  <i data-lucide="shield" class="w-4 h-4 text-gray-400"></i>
                  <span class="text-xs text-gray-400">Admin</span>
                </div>
              </label>
            </div>
          </div>

          <!-- Submit -->
          <button type="submit"
            class="w-full flex items-center justify-center gap-2 bg-red-600 hover:bg-red-700 text-white font-semibold py-3 rounded-xl transition mt-2">
            <i data-lucide="log-in" class="w-4 h-4"></i> Sign In
          </button>

        </form>

        <p class="text-center text-gray-500 text-sm mt-5">
          Don't have an account?
          <a href="/auth/register" class="text-red-400 hover:text-red-300 transition font-medium">Create one</a>
        </p>

      </div>
    </div>
  </div>

  <!-- ── Forgot Password Modal ── -->
  <div id="forgotModal" class="fixed inset-0 z-50 items-center justify-center p-4" style="display:none">
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" onclick="closeForgotModal()"></div>

    <!-- Panel -->
    <div class="relative bg-gray-900 border border-gray-700 rounded-2xl shadow-2xl w-full max-w-md p-8 z-10">
      <div class="flex items-center justify-between mb-1">
        <div class="flex items-center gap-2">
          <div class="w-8 h-8 bg-red-600/20 rounded-xl flex items-center justify-center">
            <i data-lucide="key-round" class="w-4 h-4 text-red-400"></i>
          </div>
          <h3 class="text-lg font-bold text-white">Reset Password</h3>
        </div>
        <button onclick="closeForgotModal()"
          class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-gray-800 text-gray-400 hover:text-white transition">
          <i data-lucide="x" class="w-4 h-4"></i>
        </button>
      </div>
      <p class="text-gray-500 text-sm mb-6">Enter your registered email and choose a new password.</p>

      <!-- Reset error -->
      <% if (typeof resetError !== 'undefined' && resetError) { %>
        <div id="resetErrorBanner" class="flex items-center gap-2 bg-red-500/20 border border-red-500/50 text-red-400 px-4 py-3 rounded-xl mb-5 text-sm">
          <i data-lucide="alert-circle" class="w-4 h-4 flex-shrink-0"></i>
          <%= resetError %>
        </div>
      <% } %>

      <form action="/auth/forgot-password" method="POST" class="space-y-4">

        <!-- Email -->
        <div>
          <label class="block text-gray-400 text-xs mb-1.5 font-medium uppercase tracking-wider">Email Address</label>
          <div class="relative">
            <i data-lucide="mail" class="w-4 h-4 absolute left-3.5 top-3 text-gray-500"></i>
            <input type="email" name="email" required placeholder="you@example.com"
              value="<%= typeof resetEmail !== 'undefined' ? resetEmail : '' %>"
              class="w-full bg-gray-800 text-white border border-gray-700 rounded-xl pl-10 pr-4 py-2.5 text-sm focus:outline-none focus:border-red-500 transition"/>
          </div>
        </div>

        <!-- New Password -->
        <div>
          <label class="block text-gray-400 text-xs mb-1.5 font-medium uppercase tracking-wider">New Password</label>
          <div class="relative">
            <i data-lucide="lock" class="w-4 h-4 absolute left-3.5 top-3 text-gray-500"></i>
            <input type="password" name="newPassword" id="resetPassword" required placeholder="Min. 8 characters"
              class="w-full bg-gray-800 text-white border border-gray-700 rounded-xl pl-10 pr-11 py-2.5 text-sm focus:outline-none focus:border-red-500 transition"/>
            <button type="button" onclick="togglePassword('resetPassword', 'resetEye')"
              class="absolute right-3.5 top-3 text-gray-500 hover:text-gray-300 transition">
              <i data-lucide="eye" id="resetEye" class="w-4 h-4"></i>
            </button>
          </div>
        </div>

        <!-- Confirm Password -->
        <div>
          <label class="block text-gray-400 text-xs mb-1.5 font-medium uppercase tracking-wider">Confirm New Password</label>
          <div class="relative">
            <i data-lucide="lock" class="w-4 h-4 absolute left-3.5 top-3 text-gray-500"></i>
            <input type="password" name="confirmPassword" id="resetConfirm" required placeholder="Repeat your password"
              class="w-full bg-gray-800 text-white border border-gray-700 rounded-xl pl-10 pr-11 py-2.5 text-sm focus:outline-none focus:border-red-500 transition"/>
            <button type="button" onclick="togglePassword('resetConfirm', 'resetConfirmEye')"
              class="absolute right-3.5 top-3 text-gray-500 hover:text-gray-300 transition">
              <i data-lucide="eye" id="resetConfirmEye" class="w-4 h-4"></i>
            </button>
          </div>
        </div>

        <div class="flex gap-3 pt-1">
          <button type="submit"
            class="flex-1 flex items-center justify-center gap-2 bg-red-600 hover:bg-red-700 text-white font-semibold py-2.5 rounded-xl transition">
            <i data-lucide="check" class="w-4 h-4"></i> Reset Password
          </button>
          <button type="button" onclick="closeForgotModal()"
            class="px-5 bg-gray-800 hover:bg-gray-700 text-gray-300 font-semibold py-2.5 rounded-xl transition">
            Cancel
          </button>
        </div>
      </form>
    </div>
  </div>

  <script>
    lucide.createIcons();

    function togglePassword(inputId, iconId) {
      const input = document.getElementById(inputId);
      const icon  = document.getElementById(iconId);
      if (input.type === 'password') {
        input.type = 'text';
        icon.setAttribute('data-lucide', 'eye-off');
      } else {
        input.type = 'password';
        icon.setAttribute('data-lucide', 'eye');
      }
      lucide.createIcons();
    }

    // ── Forgot password modal ──
    function openForgotModal() {
      document.getElementById('forgotModal').style.display = 'flex';
    }
    function closeForgotModal() {
      document.getElementById('forgotModal').style.display = 'none';
    }
    // Auto-open if there was a reset error (form was re-rendered with error)
    <% if (typeof resetError !== 'undefined' && resetError) { %>
      openForgotModal();
    <% } %>
    // Keyboard: close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeForgotModal();
    });

    // ── Radio button visual update ──
    document.querySelectorAll('input[name="role"]').forEach(radio => {
      radio.addEventListener('change', () => {
        document.querySelectorAll('input[name="role"]').forEach(r => {
          const div = r.nextElementSibling;
          const icon = div.querySelector('i');
          div.classList.remove('border-red-500', 'bg-red-500/10');
          div.classList.add('border-gray-700');
          icon.classList.remove('text-red-400');
          icon.classList.add('text-gray-400');
        });
        const div  = radio.nextElementSibling;
        const icon = div.querySelector('i');
        div.classList.add('border-red-500', 'bg-red-500/10');
        div.classList.remove('border-gray-700');
        icon.classList.add('text-red-400');
        icon.classList.remove('text-gray-400');
      });
    });
  </script>
</body>
</html>