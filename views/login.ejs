<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ViewTube — Login</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-950 min-h-screen flex items-center justify-center">

  <div class="bg-gray-900 p-8 rounded-2xl shadow-2xl w-full max-w-md">
    
    <!-- Logo -->
    <div class="text-center mb-8">
      <h1 class="text-4xl font-bold text-red-500">View<span class="text-white">Tube</span></h1>
      <p class="text-gray-400 mt-1 text-sm">Sign in to continue</p>
    </div>

    <!-- Error Message -->
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="bg-red-500/20 border border-red-500 text-red-400 px-4 py-3 rounded-lg mb-4 text-sm">
        <%= error %>
      </div>
    <% } %>

    <!-- Form -->
    <form action="/auth/login" method="POST" class="space-y-5">
      
      <!-- Email -->
      <div>
        <label class="block text-gray-400 text-sm mb-1">Email Address</label>
        <input 
          type="email" 
          name="email" 
          required
          placeholder="you@example.com"
          class="w-full bg-gray-800 text-white border border-gray-700 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-red-500 transition"
        />
      </div>

      <!-- Password -->
      <div>
        <label class="block text-gray-400 text-sm mb-1">Password</label>
        <input 
          type="password" 
          name="password" 
          required
          placeholder="••••••••"
          class="w-full bg-gray-800 text-white border border-gray-700 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-red-500 transition"
        />
      </div>

      <!-- Role -->
      <div>
        <label class="block text-gray-400 text-sm mb-2">Login As</label>
        <div class="flex gap-4">
          <label class="flex items-center gap-2 text-gray-300 text-sm cursor-pointer">
            <input type="radio" name="role" value="viewer" checked class="accent-red-500"> Viewer
          </label>
          <label class="flex items-center gap-2 text-gray-300 text-sm cursor-pointer">
            <input type="radio" name="role" value="creator" class="accent-red-500"> Creator
          </label>
          <label class="flex items-center gap-2 text-gray-300 text-sm cursor-pointer">
            <input type="radio" name="role" value="admin" class="accent-red-500"> Admin
          </label>
        </div>
      </div>

      <!-- Submit -->
      <button 
        type="submit"
        class="w-full bg-red-600 hover:bg-red-700 text-white font-semibold py-2.5 rounded-lg transition text-sm mt-2">
        Sign In
      </button>

    </form>

    <!-- Register Link -->
    <p class="text-center text-gray-500 text-sm mt-6">
      Don't have an account? 
      <a href="/auth/register" class="text-red-400 hover:text-red-300 transition">Register here</a>
    </p>

  </div>

</body>
</html>