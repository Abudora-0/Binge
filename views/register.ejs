<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Binge — Create Account</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
</head>
<body class="bg-gray-950 min-h-screen flex">

  <!-- Left Panel -->
  <div class="hidden lg:flex w-1/2 bg-gradient-to-br from-red-900/40 via-gray-900 to-gray-950 flex-col items-center justify-center p-12 relative overflow-hidden">
    <div class="absolute inset-0 opacity-5">
      <div class="grid grid-cols-8 gap-2 h-full">
        <% for(let i=0; i<64; i++) { %>
          <div class="bg-red-500 rounded"></div>
        <% } %>
      </div>
    </div>
    <div class="relative z-10 text-center">
      <h1 class="text-6xl font-bold text-red-500 mb-4">Binge</h1>
      <p class="text-gray-300 text-xl mb-2">Start Your Journey</p>
      <p class="text-gray-500 text-sm max-w-xs">Create an account as a viewer to watch content or as a creator to start uploading your videos.</p>
      <div class="mt-10 space-y-4 text-left max-w-xs">
        <div class="flex items-center gap-3 bg-gray-800/50 rounded-xl p-3">
          <div class="w-8 h-8 bg-red-600/20 rounded-lg flex items-center justify-center flex-shrink-0">
            <i data-lucide="play-circle" class="w-4 h-4 text-red-400"></i>
          </div>
          <div>
            <p class="text-white text-sm font-medium">Watch Videos</p>
            <p class="text-gray-400 text-xs">Browse 70+ videos across 7 categories</p>
          </div>
        </div>
        <div class="flex items-center gap-3 bg-gray-800/50 rounded-xl p-3">
          <div class="w-8 h-8 bg-red-600/20 rounded-lg flex items-center justify-center flex-shrink-0">
            <i data-lucide="upload" class="w-4 h-4 text-red-400"></i>
          </div>
          <div>
            <p class="text-white text-sm font-medium">Upload Content</p>
            <p class="text-gray-400 text-xs">Register as creator and grow your audience</p>
          </div>
        </div>
        <div class="flex items-center gap-3 bg-gray-800/50 rounded-xl p-3">
          <div class="w-8 h-8 bg-red-600/20 rounded-lg flex items-center justify-center flex-shrink-0">
            <i data-lucide="heart" class="w-4 h-4 text-red-400"></i>
          </div>
          <div>
            <p class="text-white text-sm font-medium">Like & Comment</p>
            <p class="text-gray-400 text-xs">Engage with content and build community</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Right Panel -->
  <div class="flex-1 flex items-center justify-center p-6 bg-gray-950 overflow-y-auto">
    <div class="w-full max-w-md py-8">

      <div class="lg:hidden text-center mb-8">
        <h1 class="text-4xl font-bold text-red-500">Binge</h1>
      </div>

      <div class="bg-gray-900 rounded-2xl p-8 shadow-2xl border border-gray-800">

        <h2 class="text-2xl text-red-500 font-bold mb-1">Create Account</h2>
        <p class="text-gray-400 text-sm mb-6">Join Binge today — it's free</p>

        <!-- Error -->
        <% if (typeof error !== 'undefined' && error) { %>
          <div class="flex items-center gap-2 bg-red-500/20 border border-red-500/50 text-red-400 px-4 py-3 rounded-xl mb-5 text-sm">
            <i data-lucide="alert-circle" class="w-4 h-4 flex-shrink-0"></i>
            <%= error %>
          </div>
        <% } %>

        <!-- Success -->
        <% if (typeof success !== 'undefined' && success) { %>
          <div class="flex items-center gap-2 bg-green-500/20 border border-green-500/50 text-green-400 px-4 py-3 rounded-xl mb-5 text-sm">
            <i data-lucide="check-circle" class="w-4 h-4 flex-shrink-0"></i>
            <%= success %>
          </div>
        <% } %>

        <form action="/auth/register" method="POST" class="space-y-4">

          <!-- Name Row -->
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-gray-400 text-sm mb-1.5">First Name</label>
              <div class="relative">
                <i data-lucide="user" class="w-4 h-4 absolute left-3.5 top-3 text-gray-500"></i>
                <input type="text" name="firstName" required placeholder="Ali"
                  class="w-full bg-gray-800 text-white border border-gray-700 rounded-xl pl-10 pr-4 py-2.5 text-sm focus:outline-none focus:border-red-500 transition"/>
              </div>
            </div>
            <div>
              <label class="block text-gray-400 text-sm mb-1.5">Last Name</label>
              <div class="relative">
                <i data-lucide="user" class="w-4 h-4 absolute left-3.5 top-3 text-gray-500"></i>
                <input type="text" name="lastName" required placeholder="Hassan"
                  class="w-full bg-gray-800 text-white border border-gray-700 rounded-xl pl-10 pr-4 py-2.5 text-sm focus:outline-none focus:border-red-500 transition"/>
              </div>
            </div>
          </div>

          <!-- Email -->
          <div>
            <label class="block text-gray-400 text-sm mb-1.5">Email Address</label>
            <div class="relative">
              <i data-lucide="mail" class="w-4 h-4 absolute left-3.5 top-3 text-gray-500"></i>
              <input type="email" name="email" required placeholder="you@example.com"
                class="w-full bg-gray-800 text-white border border-gray-700 rounded-xl pl-10 pr-4 py-2.5 text-sm focus:outline-none focus:border-red-500 transition"/>
            </div>
          </div>

          <!-- Password -->
          <div>
            <label class="block text-gray-400 text-sm mb-1.5">Password</label>
            <div class="relative">
              <i data-lucide="lock" class="w-4 h-4 absolute left-3.5 top-3 text-gray-500"></i>
              <input type="password" name="password" id="regPassword" required placeholder="Min 8 characters" minlength="8"
                class="w-full bg-gray-800 text-white border border-gray-700 rounded-xl pl-10 pr-11 py-2.5 text-sm focus:outline-none focus:border-red-500 transition"/>
              <button type="button" onclick="togglePassword('regPassword', 'regEye')"
                class="absolute right-3.5 top-3 text-gray-500 hover:text-gray-300 transition">
                <i data-lucide="eye" id="regEye" class="w-4 h-4"></i>
              </button>
            </div>
          </div>

          <!-- Confirm Password -->
          <div>
            <label class="block text-gray-400 text-sm mb-1.5">Confirm Password</label>
            <div class="relative">
              <i data-lucide="lock" class="w-4 h-4 absolute left-3.5 top-3 text-gray-500"></i>
              <input type="password" name="confirmPassword" id="confirmPassword" required placeholder="Re-enter password"
                class="w-full bg-gray-800 text-white border border-gray-700 rounded-xl pl-10 pr-11 py-2.5 text-sm focus:outline-none focus:border-red-500 transition"/>
              <button type="button" onclick="togglePassword('confirmPassword', 'confirmEye')"
                class="absolute right-3.5 top-3 text-gray-500 hover:text-gray-300 transition">
                <i data-lucide="eye" id="confirmEye" class="w-4 h-4"></i>
              </button>
            </div>
          </div>

          <!-- Country -->
          <div>
            <label class="block text-gray-400 text-sm mb-1.5">Country</label>
            <div class="relative">
              <i data-lucide="globe" class="w-4 h-4 absolute left-3.5 top-3 text-gray-500"></i>
              <select name="country"
                class="w-full bg-gray-800 text-white border border-gray-700 rounded-xl pl-10 pr-4 py-2.5 text-sm focus:outline-none focus:border-red-500 transition appearance-none">
                <option value="Pakistan">Pakistan</option>
                <option value="India">India</option>
                <option value="USA">USA</option>
                <option value="UK">UK</option>
                <option value="Canada">Canada</option>
                <option value="Australia">Australia</option>
                <option value="UAE">UAE</option>
                <option value="Saudi Arabia">Saudi Arabia</option>
                <option value="Other">Other</option>
              </select>
            </div>
          </div>

          <!-- Role -->
          <div>
            <label class="block text-gray-400 text-sm mb-2">Register As</label>
            <div class="grid grid-cols-2 gap-3">
              <label class="cursor-pointer">
                <input type="radio" name="role" value="viewer" checked class="peer hidden">
                <div class="flex items-center gap-3 px-4 py-3 rounded-xl border border-gray-700 peer-checked:border-red-500 peer-checked:bg-red-500/10 hover:border-gray-500 transition">
                  <i data-lucide="user" class="w-5 h-5 text-gray-400"></i>
                  <div>
                    <p class="text-sm font-medium text-white">Viewer</p>
                    <p class="text-xs text-gray-400">Watch content</p>
                  </div>
                </div>
              </label>
              <label class="cursor-pointer">
                <input type="radio" name="role" value="creator" class="peer hidden">
                <div class="flex items-center gap-3 px-4 py-3 rounded-xl border border-gray-700 peer-checked:border-red-500 peer-checked:bg-red-500/10 hover:border-gray-500 transition">
                  <i data-lucide="video" class="w-5 h-5 text-gray-400"></i>
                  <div>
                    <p class="text-sm font-medium text-white">Creator</p>
                    <p class="text-xs text-gray-400">Upload videos</p>
                  </div>
                </div>
              </label>
            </div>
          </div>

          <!-- Channel Name (creator only) -->
          <div id="channelNameDiv" class="hidden">
            <label class="block text-gray-400 text-sm mb-1.5">Channel Name</label>
            <div class="relative">
              <i data-lucide="tv-2" class="w-4 h-4 absolute left-3.5 top-3 text-gray-500"></i>
              <input type="text" name="channelName" placeholder="Your channel name"
                class="w-full bg-gray-800 text-white border border-gray-700 rounded-xl pl-10 pr-4 py-2.5 text-sm focus:outline-none focus:border-red-500 transition"/>
            </div>
          </div>

          <!-- Terms -->
          <div class="flex items-start gap-3">
            <input type="checkbox" name="terms" required id="terms"
              class="w-4 h-4 mt-0.5 accent-red-500 flex-shrink-0">
            <label for="terms" class="text-gray-400 text-sm cursor-pointer">
              I agree to the <span class="text-red-400">Terms of Service</span> and <span class="text-red-400">Privacy Policy</span>
            </label>
          </div>

          <!-- Submit -->
          <button type="submit"
            class="w-full flex items-center justify-center gap-2 bg-red-600 hover:bg-red-700 text-white font-semibold py-3 rounded-xl transition">
            <i data-lucide="user-plus" class="w-4 h-4"></i> Create Account
          </button>

        </form>

        <p class="text-center text-gray-500 text-sm mt-5">
          Already have an account?
          <a href="/auth/login" class="text-red-400 hover:text-red-300 transition font-medium">Sign in</a>
        </p>

      </div>
    </div>
  </div>

  <script>
    lucide.createIcons();

    function togglePassword(inputId, iconId) {
      const input = document.getElementById(inputId);
      const icon  = document.getElementById(iconId);
      if (input.type === 'password') {
        input.type = 'text';
        icon.setAttribute('data-lucide', 'eye-off');
      } else {
        input.type = 'password';
        icon.setAttribute('data-lucide', 'eye');
      }
      lucide.createIcons();
    }

    // Show channel name when creator selected
    document.querySelectorAll('input[name="role"]').forEach(radio => {
      radio.addEventListener('change', () => {
        document.getElementById('channelNameDiv').classList.toggle('hidden', radio.value !== 'creator' || !radio.checked);
      });
    });
  </script>
</body>
</html>