<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Binge — Register</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-950 min-h-screen flex items-center justify-center py-10">

  <div class="bg-gray-900 p-8 rounded-2xl shadow-2xl w-full max-w-md">

    <!-- Logo -->
    <div class="text-center mb-8">
      <h1 class="text-4xl font-bold text-red-500">Binge</h1>
      <p class="text-gray-400 mt-1 text-sm">Create your account</p>
    </div>

    <!-- Error Message -->
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="bg-red-500/20 border border-red-500 text-red-400 px-4 py-3 rounded-lg mb-4 text-sm">
        <%= error %>
      </div>
    <% } %>

    <!-- Success Message -->
    <% if (typeof success !== 'undefined' && success) { %>
      <div class="bg-green-500/20 border border-green-500 text-green-400 px-4 py-3 rounded-lg mb-4 text-sm">
        <%= success %>
      </div>
    <% } %>

    <!-- Form -->
    <form action="/auth/register" method="POST" class="space-y-4">

      <!-- First Name & Last Name -->
      <div class="flex gap-3">
        <div class="flex-1">
          <label class="block text-gray-400 text-sm mb-1">First Name</label>
          <input
            type="text"
            name="firstName"
            required
            placeholder="Ali"
            class="w-full bg-gray-800 text-white border border-gray-700 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-red-500 transition"
          />
        </div>
        <div class="flex-1">
          <label class="block text-gray-400 text-sm mb-1">Last Name</label>
          <input
            type="text"
            name="lastName"
            required
            placeholder="Hassan"
            class="w-full bg-gray-800 text-white border border-gray-700 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-red-500 transition"
          />
        </div>
      </div>

      <!-- Email -->
      <div>
        <label class="block text-gray-400 text-sm mb-1">Email Address</label>
        <input
          type="email"
          name="email"
          required
          placeholder="you@example.com"
          class="w-full bg-gray-800 text-white border border-gray-700 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-red-500 transition"
        />
      </div>

      <!-- Password -->
      <div>
        <label class="block text-gray-400 text-sm mb-1">Password</label>
        <input
          type="password"
          name="password"
          required
          placeholder="Min 8 characters"
          minlength="8"
          class="w-full bg-gray-800 text-white border border-gray-700 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-red-500 transition"
        />
      </div>

      <!-- Confirm Password -->
      <div>
        <label class="block text-gray-400 text-sm mb-1">Confirm Password</label>
        <input
          type="password"
          name="confirmPassword"
          required
          placeholder="Re-enter password"
          class="w-full bg-gray-800 text-white border border-gray-700 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-red-500 transition"
        />
      </div>

      <!-- Country -->
      <div>
        <label class="block text-gray-400 text-sm mb-1">Country</label>
        <select
          name="country"
          class="w-full bg-gray-800 text-white border border-gray-700 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-red-500 transition"
        >
          <option value="Pakistan">Pakistan</option>
          <option value="India">India</option>
          <option value="USA">USA</option>
          <option value="UK">UK</option>
          <option value="Canada">Canada</option>
          <option value="Australia">Australia</option>
          <option value="UAE">UAE</option>
          <option value="Saudi Arabia">Saudi Arabia</option>
          <option value="Other">Other</option>
        </select>
      </div>

      <!-- Role -->
      <div>
        <label class="block text-gray-400 text-sm mb-2">Register As</label>
        <div class="flex gap-6">
          <label class="flex items-center gap-2 text-gray-300 text-sm cursor-pointer">
            <input type="radio" name="role" value="viewer" checked class="accent-red-500"> Viewer
          </label>
          <label class="flex items-center gap-2 text-gray-300 text-sm cursor-pointer">
            <input type="radio" name="role" value="creator" class="accent-red-500"> Creator
          </label>
        </div>
      </div>

      <!-- Creator Channel Name (shown only if Creator selected) -->
      <div id="channelNameDiv" class="hidden">
        <label class="block text-gray-400 text-sm mb-1">Channel Name</label>
        <input
          type="text"
          name="channelName"
          placeholder="Your channel name"
          class="w-full bg-gray-800 text-white border border-gray-700 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-red-500 transition"
        />
      </div>

      <!-- Terms Checkbox -->
      <div class="flex items-center gap-2">
        <input type="checkbox" name="terms" required class="accent-red-500 w-4 h-4">
        <label class="text-gray-400 text-sm">I agree to the Terms and Conditions</label>
      </div>

      <!-- Submit -->
      <button
        type="submit"
        class="w-full bg-red-600 hover:bg-red-700 text-white font-semibold py-2.5 rounded-lg transition text-sm mt-2">
        Create Account
      </button>

    </form>

    <!-- Login Link -->
    <p class="text-center text-gray-500 text-sm mt-6">
      Already have an account?
      <a href="/auth/login" class="text-red-400 hover:text-red-300 transition">Sign in here</a>
    </p>

  </div>

  <!-- Show channel name field when Creator is selected -->
  <script>
    const radios = document.querySelectorAll('input[name="role"]');
    const channelDiv = document.getElementById('channelNameDiv');
    radios.forEach(r => {
      r.addEventListener('change', () => {
        channelDiv.classList.toggle('hidden', r.value !== 'creator' || !r.checked);
      });
    });
  </script>

</body>
</html>