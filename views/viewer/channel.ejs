<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Binge — <%= creator.ChannelName %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
</head>
<body class="bg-gray-950 text-white min-h-screen">

  <nav class="bg-gray-950 border-b border-gray-800 px-6 py-3 flex items-center justify-between sticky top-0 z-50">
    <a href="/viewer/home" class="flex items-center gap-2">
      <i data-lucide="arrow-left" class="w-5 h-5 text-gray-400 hover:text-white transition"></i>
      <span class="text-xl font-bold text-red-500">Binge</span>
    </a>
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 bg-red-600 rounded-full flex items-center justify-center font-bold text-sm">
        <%= user.firstName.charAt(0).toUpperCase() %>
      </div>
      <a href="/auth/logout" class="text-red-400 hover:text-red-300 transition">
        <i data-lucide="log-out" class="w-4 h-4"></i>
      </a>
    </div>
  </nav>

  <!-- Channel Banner -->
  <div class="bg-gradient-to-br from-red-900/30 via-gray-900 to-gray-950 h-40 relative">
    <% if (creator.BannerImage) { %>
      <img src="/uploads/<%= creator.BannerImage %>" class="w-full h-full object-cover opacity-40">
    <% } %>
  </div>

  <!-- Channel Info -->
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex items-end gap-5 -mt-12 mb-6">
      <div class="w-24 h-24 rounded-full border-4 border-gray-950 overflow-hidden flex-shrink-0 bg-red-600 flex items-center justify-center text-3xl font-bold">
        <% if (creator.Avatar) { %>
          <img src="/uploads/<%= creator.Avatar %>" class="w-full h-full object-cover">
        <% } else { %>
          <%= creator.ChannelName.charAt(0).toUpperCase() %>
        <% } %>
      </div>
      <div class="pb-2 flex-1">
        <h1 class="text-2xl font-bold"><%= creator.ChannelName %></h1>
        <div class="flex items-center gap-4 mt-1 text-gray-400 text-sm flex-wrap">
          <span class="flex items-center gap-1">
            <i data-lucide="users" class="w-4 h-4"></i>
            <%= creator.TotalSubscribers.toLocaleString() %> subscribers
          </span>
          <span class="flex items-center gap-1">
            <i data-lucide="play-circle" class="w-4 h-4"></i>
            <%= videos.length %> videos
          </span>
          <span class="flex items-center gap-1">
            <i data-lucide="eye" class="w-4 h-4"></i>
            <%= creator.TotalViews.toLocaleString() %> total views
          </span>
        </div>
        <% if (creator.Bio) { %>
          <p class="text-gray-400 text-sm mt-1"><%= creator.Bio %></p>
        <% } %>
      </div>
      <!-- Subscribe Button -->
      <div class="pb-2">
        <form action="/viewer/subscribe/<%= creator.Id %>" method="POST">
          <button type="submit"
            class="flex items-center gap-2 <%= subscribed ? 'bg-gray-700 text-gray-300' : 'bg-red-600 text-white' %> hover:opacity-80 px-5 py-2.5 rounded-full text-sm font-semibold transition">
            <i data-lucide="<%= subscribed ? 'bell-off' : 'bell' %>" class="w-4 h-4"></i>
            <%= subscribed ? 'Subscribed' : 'Subscribe' %>
          </button>
        </form>
      </div>
    </div>

    <!-- Videos Grid -->
    <% if (videos.length === 0) { %>
      <div class="text-center text-gray-500 mt-20">
        <i data-lucide="video-off" class="w-16 h-16 mx-auto mb-4 text-gray-700"></i>
        <p class="text-xl">No videos yet</p>
      </div>
    <% } else { %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-4 gap-y-8 pb-10">
        <% videos.forEach(video => { %>
          <a href="/viewer/watch/<%= video.Id %>" class="block group cursor-pointer">
            <div class="rounded-xl overflow-hidden aspect-video mb-3 relative bg-gray-800">
              <% if (video.thumbnail) { %>
                <img src="<%= video.thumbnail %>" alt="<%= video.Title %>"
                     class="w-full h-full object-cover group-hover:brightness-75 transition"
                     onerror="this.style.display='none'">
              <% } else { %>
                <div class="w-full h-full flex items-center justify-center">
                  <i data-lucide="play-circle" class="w-14 h-14 text-gray-600"></i>
                </div>
              <% } %>
              <span class="absolute bottom-2 right-2 bg-black/80 text-white text-xs px-1.5 py-0.5 rounded font-medium">
                <%= Math.floor(video.Duration/60) %>:<%= String(video.Duration%60).padStart(2,'0') %>
              </span>
            </div>
            <div>
              <h3 class="text-white text-sm font-semibold line-clamp-2 mb-1 group-hover:text-red-400 transition"><%= video.Title %></h3>
              <p class="text-gray-500 text-xs flex items-center gap-1">
                <i data-lucide="eye" class="w-3 h-3"></i>
                <%= video.Views.toLocaleString() %> views · <%= new Date(video.UploadDate).toLocaleDateString() %>
              </p>
            </div>
          </a>
        <% }) %>
      </div>
    <% } %>
  </div>

  <script>lucide.createIcons();</script>
</body>
</html>