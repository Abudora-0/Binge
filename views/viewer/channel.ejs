<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Binge — <%= creator.ChannelName %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
</head>
<body class="bg-gray-950 text-white min-h-screen flex flex-col">

  <!-- Navbar -->
  <nav class="bg-gray-950 border-b border-gray-800 px-4 py-3 flex items-center gap-4 sticky top-0 z-50">
    <div class="flex items-center gap-3 w-48 flex-shrink-0">
      <a href="/viewer/home" class="text-gray-400 hover:text-white p-1.5 rounded-lg hover:bg-gray-800 transition">
        <i data-lucide="arrow-left" class="w-5 h-5"></i>
      </a>
      <a href="/viewer/home" class="text-xl font-bold text-red-500">Binge</a>
    </div>
    <div class="flex-1 flex gap-2 max-w-2xl mx-auto">
      <input type="text" placeholder="Search videos..."
        class="flex-1 bg-gray-900 text-white border border-gray-700 rounded-full px-5 py-2 text-sm focus:outline-none focus:border-red-500 transition"/>
      <button class="bg-gray-800 hover:bg-gray-700 px-5 py-2 rounded-full border border-gray-700 transition">
        <i data-lucide="search" class="w-4 h-4"></i>
      </button>
    </div>
    <div class="w-48 flex-shrink-0 flex justify-end relative">
      <button onclick="toggleProfile()"
        class="flex items-center gap-2 hover:bg-gray-800 px-3 py-1.5 rounded-full transition">
        <div class="w-8 h-8 rounded-full overflow-hidden flex-shrink-0 bg-red-600 flex items-center justify-center font-bold text-sm">
          <% if (user.avatar) { %>
            <img src="/uploads/<%= user.avatar %>" class="w-full h-full object-cover">
          <% } else { %>
            <%= user.firstName.charAt(0).toUpperCase() %>
          <% } %>
        </div>
        <span class="text-white text-sm font-medium hidden sm:block"><%= user.firstName %></span>
        <i data-lucide="chevron-down" class="w-4 h-4 text-gray-400"></i>
      </button>
      <div id="profileDropdown"
        class="hidden absolute top-12 right-0 bg-gray-900 border border-gray-700 rounded-xl shadow-2xl w-56 z-50 overflow-hidden">
        <div class="px-4 py-3 border-b border-gray-700 flex items-center gap-3">
          <div class="w-10 h-10 rounded-full overflow-hidden bg-red-600 flex items-center justify-center font-bold text-sm">
            <% if (user.avatar) { %>
              <img src="/uploads/<%= user.avatar %>" class="w-full h-full object-cover">
            <% } else { %>
              <%= user.firstName.charAt(0).toUpperCase() %>
            <% } %>
          </div>
          <div>
            <p class="text-white text-sm font-semibold"><%= user.firstName %> <%= user.lastName %></p>
            <p class="text-gray-400 text-xs"><%= user.email %></p>
          </div>
        </div>
        <div class="py-1">
          <a href="/viewer/profile"
            class="flex items-center gap-3 px-4 py-2.5 text-gray-300 hover:bg-gray-800 text-sm transition">
            <i data-lucide="user-circle" class="w-4 h-4"></i> My Profile
          </a>
          <a href="/viewer/history"
            class="flex items-center gap-3 px-4 py-2.5 text-gray-300 hover:bg-gray-800 text-sm transition">
            <i data-lucide="history" class="w-4 h-4"></i> Watch History
          </a>
          <a href="/viewer/playlists"
            class="flex items-center gap-3 px-4 py-2.5 text-gray-300 hover:bg-gray-800 text-sm transition">
            <i data-lucide="list-music" class="w-4 h-4"></i> Playlists
          </a>
          <a href="/viewer/subscriptions"
            class="flex items-center gap-3 px-4 py-2.5 text-gray-300 hover:bg-gray-800 text-sm transition">
            <i data-lucide="bell" class="w-4 h-4"></i> Subscriptions
          </a>
          <div class="border-t border-gray-700 my-1"></div>
          <a href="/auth/logout"
            class="flex items-center gap-3 px-4 py-2.5 text-red-400 hover:bg-gray-800 text-sm transition">
            <i data-lucide="log-out" class="w-4 h-4"></i> Sign Out
          </a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Channel Banner -->
  <div class="relative h-48 bg-gradient-to-br from-red-900/60 via-gray-900 to-gray-950 overflow-hidden">
    <% if (creator.BannerImage) { %>
      <img src="/uploads/<%= creator.BannerImage %>" class="w-full h-full object-cover opacity-50">
    <% } %>
    <!-- Decorative pattern -->
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-4 left-10 w-32 h-32 bg-red-500 rounded-full blur-3xl"></div>
      <div class="absolute bottom-4 right-20 w-48 h-48 bg-red-700 rounded-full blur-3xl"></div>
    </div>
  </div>

  <!-- Channel Info -->
  <div class="max-w-6xl mx-auto px-6 w-full">

    <!-- Profile Row -->
    <div class="flex items-end gap-5 -mt-14 mb-0 pb-5 border-b border-gray-800">
      <!-- Avatar -->
      <div class="w-28 h-28 rounded-full border-4 border-gray-950 overflow-hidden flex-shrink-0 bg-red-600 flex items-center justify-center text-4xl font-bold shadow-xl">
        <% if (creator.Avatar) { %>
          <img src="/uploads/<%= creator.Avatar %>" class="w-full h-full object-cover">
        <% } else { %>
          <%= creator.ChannelName.charAt(0).toUpperCase() %>
        <% } %>
      </div>

      <!-- Info -->
      <div class="flex-1 pb-2">
        <h1 class="text-2xl font-bold"><%= creator.ChannelName %></h1>
        <% if (creator.Bio) { %>
          <p class="text-gray-400 text-sm mt-1"><%= creator.Bio %></p>
        <% } %>
        <div class="flex items-center gap-4 mt-2 flex-wrap">
          <span class="flex items-center gap-1.5 text-gray-400 text-sm">
            <i data-lucide="users" class="w-4 h-4"></i>
            <span class="font-medium text-white"><%= creator.TotalSubscribers.toLocaleString() %></span> subscribers
          </span>
          <span class="text-gray-700">•</span>
          <span class="flex items-center gap-1.5 text-gray-400 text-sm">
            <i data-lucide="play-circle" class="w-4 h-4"></i>
            <span class="font-medium text-white"><%= videos.length %></span> videos
          </span>
          <span class="text-gray-700">•</span>
          <span class="flex items-center gap-1.5 text-gray-400 text-sm">
            <i data-lucide="eye" class="w-4 h-4"></i>
            <span class="font-medium text-white"><%= creator.TotalViews.toLocaleString() %></span> total views
          </span>
        </div>
      </div>

      <!-- Subscribe Button -->
      <div class="pb-2">
        <form action="/viewer/subscribe/<%= creator.Id %>" method="POST">
          <button type="submit"
            class="flex items-center gap-2 <%= subscribed ? 'bg-gray-700 hover:bg-gray-600 text-gray-200' : 'bg-red-600 hover:bg-red-700 text-white' %> px-6 py-2.5 rounded-full text-sm font-semibold transition">
            <i data-lucide="<%= subscribed ? 'bell-off' : 'bell' %>" class="w-4 h-4"></i>
            <%= subscribed ? 'Subscribed' : 'Subscribe' %>
          </button>
        </form>
      </div>
    </div>

    <!-- Videos Section -->
    <div class="py-8">
      <h2 class="text-lg font-bold mb-6 flex items-center gap-2">
        <i data-lucide="play-square" class="w-5 h-5 text-red-500"></i>
        Videos
        <span class="text-gray-500 text-sm font-normal ml-1">(<%= videos.length %>)</span>
      </h2>

      <% if (videos.length === 0) { %>
        <div class="text-center py-20">
          <div class="w-20 h-20 bg-gray-800 rounded-full flex items-center justify-center mx-auto mb-4">
            <i data-lucide="video-off" class="w-10 h-10 text-gray-600"></i>
          </div>
          <p class="text-gray-400 text-lg font-medium">No videos yet</p>
          <p class="text-gray-500 text-sm mt-1">This creator hasn't uploaded anything yet</p>
        </div>
      <% } else { %>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-4 gap-y-8 pb-12">
          <% videos.forEach(video => { %>
            <a href="/viewer/watch/<%= video.Id %>" class="block group cursor-pointer">

              <!-- Thumbnail -->
              <div class="rounded-xl overflow-hidden aspect-video mb-3 relative bg-gray-800">
                <% if (video.thumbnail) { %>
                  <img src="<%= video.thumbnail %>" alt="<%= video.Title %>"
                       class="w-full h-full object-cover group-hover:brightness-75 transition"
                       onerror="this.style.display='none'">
                <% } else { %>
                  <div class="w-full h-full flex items-center justify-center">
                    <i data-lucide="play-circle" class="w-14 h-14 text-gray-600"></i>
                  </div>
                <% } %>
                <!-- Duration -->
                <span class="absolute bottom-2 right-2 bg-black/80 text-white text-xs px-1.5 py-0.5 rounded font-medium">
                  <%= Math.floor(video.Duration/60) %>:<%= String(video.Duration%60).padStart(2,'0') %>
                </span>
                <!-- Play overlay -->
                <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition">
                  <div class="w-12 h-12 bg-red-600/90 rounded-full flex items-center justify-center">
                    <i data-lucide="play" class="w-5 h-5 text-white ml-0.5"></i>
                  </div>
                </div>
              </div>

              <!-- Info -->
              <div>
                <h3 class="text-white text-sm font-semibold line-clamp-2 leading-snug mb-1 group-hover:text-red-400 transition">
                  <%= video.Title %>
                </h3>
                <div class="flex items-center gap-2 text-gray-500 text-xs">
                  <span class="flex items-center gap-1">
                    <i data-lucide="eye" class="w-3 h-3"></i>
                    <%= video.Views.toLocaleString() %> views
                  </span>
                  <span>•</span>
                  <span><%= new Date(video.UploadDate).toLocaleDateString() %></span>
                </div>
              </div>

            </a>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>

  <script>
    lucide.createIcons();

    function toggleProfile() {
      document.getElementById('profileDropdown').classList.toggle('hidden');
    }

    document.addEventListener('click', (e) => {
      if (!e.target.closest('.relative') && !e.target.closest('[onclick="toggleProfile()"]')) {
        document.getElementById('profileDropdown').classList.add('hidden');
      }
    });
  </script>
</body>
</html>