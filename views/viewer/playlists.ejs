<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Binge — Playlists</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
</head>
<body class="bg-gray-950 text-white min-h-screen flex flex-col">

  <!-- Navbar -->
  <nav class="bg-gray-950 border-b border-gray-800 px-4 py-3 flex items-center gap-4 sticky top-0 z-50">
    <div class="flex items-center gap-3 w-48 flex-shrink-0">
      <a href="/viewer/home" class="flex items-center gap-2 text-gray-400 hover:text-white transition">
        <i data-lucide="arrow-left" class="w-5 h-5"></i>
      </a>
      <a href="/viewer/home" class="text-xl font-bold text-red-500">Binge</a>
    </div>
    <div class="flex-1"></div>
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 bg-red-600 rounded-full flex items-center justify-center font-bold text-sm">
        <%= user.firstName.charAt(0).toUpperCase() %>
      </div>
      <span class="text-white text-sm font-medium"><%= user.firstName %></span>
      <a href="/auth/logout" class="flex items-center gap-2 text-red-400 hover:text-red-300 text-sm transition">
        <i data-lucide="log-out" class="w-4 h-4"></i>
      </a>
    </div>
  </nav>

  <div class="max-w-5xl mx-auto px-6 py-8 w-full">

    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-purple-600/20 rounded-xl flex items-center justify-center">
          <i data-lucide="list-music" class="w-5 h-5 text-purple-400"></i>
        </div>
        <div>
          <h2 class="text-2xl font-bold">Playlists</h2>
          <p class="text-gray-400 text-sm"><%= playlists.length %> playlist<%= playlists.length !== 1 ? 's' : '' %></p>
        </div>
      </div>
      <button onclick="document.getElementById('createModal').classList.remove('hidden')"
              class="flex items-center gap-2 bg-red-600 hover:bg-red-700 text-white text-sm px-4 py-2.5 rounded-full transition">
        <i data-lucide="plus" class="w-4 h-4"></i> New Playlist
      </button>
    </div>

    <% if (playlists.length === 0) { %>
      <div class="text-center mt-20">
        <div class="w-20 h-20 bg-gray-800 rounded-full flex items-center justify-center mx-auto mb-4">
          <i data-lucide="list-music" class="w-10 h-10 text-gray-600"></i>
        </div>
        <h3 class="text-xl font-semibold text-gray-300 mb-2">No playlists yet</h3>
        <p class="text-gray-500 text-sm mb-6">Create a playlist to organize your favourite videos</p>
        <button onclick="document.getElementById('createModal').classList.remove('hidden')"
                class="inline-flex items-center gap-2 bg-red-600 hover:bg-red-700 text-white px-6 py-2.5 rounded-full text-sm transition">
          <i data-lucide="plus" class="w-4 h-4"></i> Create Playlist
        </button>
      </div>
    <% } else { %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <% playlists.forEach(p => { %>
          <div class="bg-gray-900 rounded-2xl overflow-hidden hover:bg-gray-800 transition group cursor-pointer">

            <!-- Thumbnail Area -->
            <div class="relative h-36 bg-gradient-to-br from-purple-900/40 to-gray-800 flex items-center justify-center">
              <i data-lucide="list-music" class="w-12 h-12 text-gray-600 group-hover:text-purple-400 transition"></i>
              <div class="absolute top-3 right-3">
                <span class="bg-black/60 text-white text-xs px-2 py-1 rounded-lg flex items-center gap-1">
                  <i data-lucide="play-circle" class="w-3 h-3"></i>
                  <%= p.TotalVideos %> videos
                </span>
              </div>
            </div>

            <!-- Info -->
            <div class="p-4">
              <h3 class="font-semibold truncate mb-1"><%= p.Title %></h3>
              <% if (p.Description) { %>
                <p class="text-gray-400 text-xs line-clamp-1 mb-3"><%= p.Description %></p>
              <% } %>
              <div class="flex items-center justify-between">
                <span class="text-xs px-2 py-1 rounded-full flex items-center gap-1
                  <%= p.Visibility === 'Public' ? 'bg-green-500/20 text-green-400' : 'bg-gray-500/20 text-gray-400' %>">
                  <i data-lucide="<%= p.Visibility === 'Public' ? 'globe' : 'lock' %>" class="w-3 h-3"></i>
                  <%= p.Visibility %>
                </span>
                <span class="text-gray-500 text-xs flex items-center gap-1">
                  <i data-lucide="calendar" class="w-3 h-3"></i>
                  <%= new Date(p.CreatedAt).toLocaleDateString() %>
                </span>
              </div>
            </div>

          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <!-- Create Playlist Modal -->
  <div id="createModal" class="hidden fixed inset-0 bg-black/70 backdrop-blur-sm flex items-center justify-center z-50">
    <div class="bg-gray-900 border border-gray-700 rounded-2xl p-6 w-full max-w-md mx-4 shadow-2xl">
      <div class="flex items-center justify-between mb-5">
        <h3 class="font-bold text-lg flex items-center gap-2">
          <i data-lucide="plus-circle" class="w-5 h-5 text-red-500"></i>
          Create New Playlist
        </h3>
        <button onclick="document.getElementById('createModal').classList.add('hidden')"
                class="text-gray-400 hover:text-white transition">
          <i data-lucide="x" class="w-5 h-5"></i>
        </button>
      </div>

      <form action="/viewer/playlist/create" method="POST" class="space-y-4">
        <div>
          <label class="block text-gray-400 text-sm mb-1.5">Title <span class="text-red-500">*</span></label>
          <input type="text" name="title" required placeholder="My Awesome Playlist"
            class="w-full bg-gray-800 text-white border border-gray-700 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-red-500 transition">
        </div>
        <div>
          <label class="block text-gray-400 text-sm mb-1.5">Description</label>
          <textarea name="description" rows="3" placeholder="What's this playlist about?"
            class="w-full bg-gray-800 text-white border border-gray-700 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-red-500 transition resize-none"></textarea>
        </div>
        <div>
          <label class="block text-gray-400 text-sm mb-2">Visibility</label>
          <div class="flex gap-4">
            <label class="flex items-center gap-2 text-sm text-gray-300 cursor-pointer bg-gray-800 px-4 py-2 rounded-xl border border-gray-700 hover:border-red-500 transition flex-1 justify-center">
              <input type="radio" name="visibility" value="Public" checked class="accent-red-500">
              <i data-lucide="globe" class="w-4 h-4"></i> Public
            </label>
            <label class="flex items-center gap-2 text-sm text-gray-300 cursor-pointer bg-gray-800 px-4 py-2 rounded-xl border border-gray-700 hover:border-red-500 transition flex-1 justify-center">
              <input type="radio" name="visibility" value="Private" class="accent-red-500">
              <i data-lucide="lock" class="w-4 h-4"></i> Private
            </label>
          </div>
        </div>
        <div class="flex gap-3 pt-2">
          <button type="submit"
            class="flex-1 flex items-center justify-center gap-2 bg-red-600 hover:bg-red-700 text-white py-2.5 rounded-xl text-sm transition">
            <i data-lucide="plus" class="w-4 h-4"></i> Create
          </button>
          <button type="button"
            onclick="document.getElementById('createModal').classList.add('hidden')"
            class="flex-1 flex items-center justify-center gap-2 bg-gray-800 hover:bg-gray-700 text-white py-2.5 rounded-xl text-sm transition">
            <i data-lucide="x" class="w-4 h-4"></i> Cancel
          </button>
        </div>
      </form>
    </div>
  </div>

  <script>lucide.createIcons();</script>
</body>
</html>