<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Binge — My Profile</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
</head>
<body class="bg-gray-950 text-white min-h-screen flex flex-col">

  <!-- Navbar -->
  <nav class="bg-gray-950 border-b border-gray-800 px-6 py-3 flex items-center justify-between sticky top-0 z-50">
    <a href="/viewer/home" class="flex items-center gap-2">
      <i data-lucide="arrow-left" class="w-5 h-5 text-gray-400 hover:text-white transition"></i>
      <span class="text-xl font-bold text-red-500">Binge</span>
    </a>
    <a href="/auth/logout" class="flex items-center gap-2 text-red-400 hover:text-red-300 text-sm transition">
      <i data-lucide="log-out" class="w-4 h-4"></i> Sign Out
    </a>
  </nav>

  <!-- Banner -->
  <div class="h-40 bg-gradient-to-r from-red-900/50 via-red-600/20 to-gray-900 relative overflow-hidden">
    <div class="absolute inset-0 flex items-center justify-center opacity-5">
      <i data-lucide="play-circle" class="w-96 h-96 text-red-500"></i>
    </div>
  </div>

  <div class="max-w-3xl mx-auto px-6 w-full -mt-16 pb-16">

    <!-- Profile Card -->
    <div class="bg-gray-900 rounded-2xl border border-gray-800 overflow-hidden shadow-2xl mb-6">

      <!-- Avatar Section -->
      <div class="px-8 pt-6 pb-6 flex items-end gap-6">
        <!-- Avatar -->
        <div class="relative flex-shrink-0">
          <div class="w-24 h-24 rounded-full border-4 border-gray-900 overflow-hidden bg-red-600 flex items-center justify-center text-3xl font-bold shadow-xl">
            <% if (userData.Avatar) { %>
              <img src="/uploads/<%= userData.Avatar %>" alt="Avatar" class="w-full h-full object-cover" id="avatarPreview">
            <% } else { %>
              <span id="avatarInitial"><%= userData.FirstName.charAt(0).toUpperCase() %></span>
              <img id="avatarPreview" class="w-full h-full object-cover hidden">
            <% } %>
          </div>
          <!-- Upload button overlay -->
          <label for="avatarInput"
            class="absolute bottom-0 right-0 w-7 h-7 bg-red-600 hover:bg-red-700 rounded-full flex items-center justify-center cursor-pointer transition shadow-lg border-2 border-gray-900">
            <i data-lucide="camera" class="w-3.5 h-3.5 text-white"></i>
          </label>
        </div>

        <!-- Name & Stats -->
        <div class="flex-1 pb-1">
          <h2 class="text-2xl font-bold"><%= userData.FirstName %> <%= userData.LastName %></h2>
          <p class="text-gray-400 text-sm flex items-center gap-1.5 mt-1">
            <i data-lucide="mail" class="w-3.5 h-3.5"></i> <%= userData.Email %>
          </p>
          <div class="flex items-center gap-4 mt-2">
            <span class="flex items-center gap-1.5 text-xs text-gray-400 bg-gray-800 px-3 py-1 rounded-full">
              <i data-lucide="globe" class="w-3 h-3"></i> <%= userData.Country %>
            </span>
            <span class="flex items-center gap-1.5 text-xs text-gray-400 bg-gray-800 px-3 py-1 rounded-full">
              <i data-lucide="shield-check" class="w-3 h-3 text-green-400"></i>
              <span class="text-green-400"><%= userData.Status %></span>
            </span>
          </div>
        </div>
      </div>

      <!-- Quick avatar upload form (hidden, triggered by camera button) -->
      <form action="/viewer/profile/avatar" method="POST" enctype="multipart/form-data" id="avatarForm" class="hidden">
        <input type="file" name="avatar" id="avatarInput" accept="image/*" class="hidden">
      </form>

      <!-- Alerts -->
      <% if (typeof success !== 'undefined' && success) { %>
        <div class="mx-8 mb-4 flex items-center gap-2 bg-green-500/20 border border-green-500/50 text-green-400 px-4 py-3 rounded-xl text-sm">
          <i data-lucide="check-circle" class="w-4 h-4 flex-shrink-0"></i> <%= success %>
        </div>
      <% } %>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="mx-8 mb-4 flex items-center gap-2 bg-red-500/20 border border-red-500/50 text-red-400 px-4 py-3 rounded-xl text-sm">
          <i data-lucide="alert-circle" class="w-4 h-4 flex-shrink-0"></i> <%= error %>
        </div>
      <% } %>

      <div class="border-t border-gray-800 mx-8"></div>

      <!-- Edit Profile Form -->
      <div class="px-8 py-6">
        <h3 class="font-semibold text-base mb-5 flex items-center gap-2 text-gray-200">
          <i data-lucide="edit-3" class="w-4 h-4 text-red-400"></i> Edit Profile
        </h3>
        <form action="/viewer/profile/update" method="POST" class="space-y-5">

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-gray-400 text-xs mb-1.5 uppercase tracking-wider">First Name</label>
              <div class="relative">
                <i data-lucide="user" class="w-4 h-4 absolute left-3.5 top-3 text-gray-500"></i>
                <input type="text" name="firstName" value="<%= userData.FirstName %>" required
                  class="w-full bg-gray-800 text-white border border-gray-700 rounded-xl pl-10 pr-4 py-2.5 text-sm focus:outline-none focus:border-red-500 transition">
              </div>
            </div>
            <div>
              <label class="block text-gray-400 text-xs mb-1.5 uppercase tracking-wider">Last Name</label>
              <div class="relative">
                <i data-lucide="user" class="w-4 h-4 absolute left-3.5 top-3 text-gray-500"></i>
                <input type="text" name="lastName" value="<%= userData.LastName %>" required
                  class="w-full bg-gray-800 text-white border border-gray-700 rounded-xl pl-10 pr-4 py-2.5 text-sm focus:outline-none focus:border-red-500 transition">
              </div>
            </div>
          </div>

          <div>
            <label class="block text-gray-400 text-xs mb-1.5 uppercase tracking-wider">Email Address</label>
            <div class="relative">
              <i data-lucide="mail" class="w-4 h-4 absolute left-3.5 top-3 text-gray-500"></i>
              <input type="email" value="<%= userData.Email %>" disabled
                class="w-full bg-gray-700/50 text-gray-500 border border-gray-700 rounded-xl pl-10 pr-4 py-2.5 text-sm cursor-not-allowed">
              <span class="absolute right-3.5 top-3 text-xs text-gray-500">Cannot change</span>
            </div>
          </div>

          <div>
            <label class="block text-gray-400 text-xs mb-1.5 uppercase tracking-wider">Country</label>
            <div class="relative">
              <i data-lucide="globe" class="w-4 h-4 absolute left-3.5 top-3 text-gray-500"></i>
              <select name="country"
                class="w-full bg-gray-800 text-white border border-gray-700 rounded-xl pl-10 pr-4 py-2.5 text-sm focus:outline-none focus:border-red-500 transition appearance-none">
                <% ['Pakistan','India','USA','UK','Canada','Australia','UAE','Saudi Arabia','Other'].forEach(c => { %>
                  <option value="<%= c %>" <%= userData.Country === c ? 'selected' : '' %>><%= c %></option>
                <% }) %>
              </select>
            </div>
          </div>

          <div class="flex gap-3 pt-2">
            <button type="submit"
              class="flex items-center gap-2 bg-red-600 hover:bg-red-700 text-white text-sm px-6 py-2.5 rounded-xl transition font-medium">
              <i data-lucide="save" class="w-4 h-4"></i> Save Changes
            </button>
            <a href="/viewer/home"
              class="flex items-center gap-2 bg-gray-800 hover:bg-gray-700 text-gray-300 text-sm px-6 py-2.5 rounded-xl transition">
              <i data-lucide="x" class="w-4 h-4"></i> Cancel
            </a>
          </div>

        </form>
      </div>
    </div>

    <!-- Quick Links -->
    <div class="grid grid-cols-3 gap-4">
      <a href="/viewer/history" class="bg-gray-900 hover:bg-gray-800 border border-gray-800 hover:border-red-500 rounded-2xl p-5 flex flex-col items-center gap-2 transition group">
        <i data-lucide="history" class="w-6 h-6 text-gray-400 group-hover:text-red-400 transition"></i>
        <span class="text-sm text-gray-300">Watch History</span>
      </a>
      <a href="/viewer/playlists" class="bg-gray-900 hover:bg-gray-800 border border-gray-800 hover:border-red-500 rounded-2xl p-5 flex flex-col items-center gap-2 transition group">
        <i data-lucide="list-music" class="w-6 h-6 text-gray-400 group-hover:text-red-400 transition"></i>
        <span class="text-sm text-gray-300">Playlists</span>
      </a>
      <a href="/viewer/subscriptions" class="bg-gray-900 hover:bg-gray-800 border border-gray-800 hover:border-red-500 rounded-2xl p-5 flex flex-col items-center gap-2 transition group">
        <i data-lucide="bell" class="w-6 h-6 text-gray-400 group-hover:text-red-400 transition"></i>
        <span class="text-sm text-gray-300">Subscriptions</span>
      </a>
    </div>

  </div>

  <script>
    lucide.createIcons();

    // Click camera icon → trigger file input → auto submit
    document.getElementById('avatarInput').addEventListener('change', function() {
      if (this.files && this.files[0]) {
        // Preview
        const reader = new FileReader();
        reader.onload = e => {
          const preview = document.getElementById('avatarPreview');
          const initial = document.getElementById('avatarInitial');
          preview.src = e.target.result;
          preview.classList.remove('hidden');
          if (initial) initial.classList.add('hidden');
        };
        reader.readAsDataURL(this.files[0]);
        // Auto submit
        document.getElementById('avatarForm').submit();
      }
    });
  </script>

</body>
</html>