<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Binge — Subscriptions</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
</head>
<body class="bg-gray-950 text-white min-h-screen flex flex-col">

  <!-- Navbar -->
  <nav class="bg-gray-950 border-b border-gray-800 px-4 py-3 flex items-center gap-4 sticky top-0 z-50">
    <div class="flex items-center gap-3 w-48 flex-shrink-0">
      <a href="/viewer/home" class="flex items-center gap-2 text-gray-400 hover:text-white transition">
        <i data-lucide="arrow-left" class="w-5 h-5"></i>
      </a>
      <a href="/viewer/home" class="text-xl font-bold text-red-500">Binge</a>
    </div>
    <div class="flex-1"></div>
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 bg-red-600 rounded-full flex items-center justify-center font-bold text-sm">
        <%= user.firstName.charAt(0).toUpperCase() %>
      </div>
      <span class="text-white text-sm font-medium"><%= user.firstName %></span>
      <a href="/auth/logout" class="flex items-center gap-2 text-red-400 hover:text-red-300 text-sm transition">
        <i data-lucide="log-out" class="w-4 h-4"></i>
      </a>
    </div>
  </nav>

  <div class="max-w-5xl mx-auto px-6 py-8 w-full">

    <!-- Header -->
    <div class="flex items-center gap-3 mb-8">
      <div class="w-10 h-10 bg-red-600/20 rounded-xl flex items-center justify-center">
        <i data-lucide="bell" class="w-5 h-5 text-red-400"></i>
      </div>
      <div>
        <h2 class="text-2xl font-bold">Subscriptions</h2>
        <p class="text-gray-400 text-sm"><%= creators.length %> channel<%= creators.length !== 1 ? 's' : '' %></p>
      </div>
    </div>

    <% if (creators.length === 0) { %>
      <div class="text-center mt-24">
        <div class="w-20 h-20 bg-gray-800 rounded-full flex items-center justify-center mx-auto mb-4">
          <i data-lucide="bell-off" class="w-10 h-10 text-gray-600"></i>
        </div>
        <h3 class="text-xl font-semibold text-gray-300 mb-2">No subscriptions yet</h3>
        <p class="text-gray-500 text-sm mb-6">Subscribe to creators to see them here</p>
        <a href="/viewer/home" class="inline-flex items-center gap-2 bg-red-600 hover:bg-red-700 text-white px-6 py-2.5 rounded-full text-sm transition">
          <i data-lucide="compass" class="w-4 h-4"></i> Browse Videos
        </a>
      </div>
    <% } else { %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <% creators.forEach(c => { %>
          <div class="bg-gray-900 rounded-2xl p-5 hover:bg-gray-800 transition group">

            <!-- Channel Banner -->
            <div class="bg-gradient-to-br from-red-600/20 to-gray-800 rounded-xl h-16 mb-4 flex items-center justify-center relative overflow-hidden">
              <div class="absolute inset-0 opacity-10">
                <div class="w-full h-full bg-gradient-to-r from-red-500 to-orange-500"></div>
              </div>
            </div>

            <!-- Avatar + Info -->
            <div class="flex items-start gap-3 mb-4">
              <div class="w-12 h-12 bg-red-600 rounded-full flex items-center justify-center text-lg font-bold flex-shrink-0 -mt-8 border-2 border-gray-900">
                <%= c.ChannelName.charAt(0).toUpperCase() %>
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="font-semibold truncate"><%= c.ChannelName %></h3>
                <div class="flex items-center gap-3 mt-1">
                  <span class="text-gray-400 text-xs flex items-center gap-1">
                    <i data-lucide="users" class="w-3 h-3"></i>
                    <%= c.TotalSubscribers.toLocaleString() %>
                  </span>
                  <span class="text-gray-400 text-xs flex items-center gap-1">
                    <i data-lucide="play-circle" class="w-3 h-3"></i>
                    <%= c.TotalVideos %> videos
                  </span>
                </div>
              </div>
            </div>

            <!-- Subscribed date -->
            <p class="text-gray-500 text-xs flex items-center gap-1 mb-4">
              <i data-lucide="calendar" class="w-3 h-3"></i>
              Subscribed <%= new Date(c.SubscribedAt).toLocaleDateString() %>
            </p>

            <!-- Unsubscribe -->
            <form action="/viewer/subscribe/<%= c.Id %>" method="POST">
              <button type="submit"
                class="w-full flex items-center justify-center gap-2 bg-gray-800 hover:bg-red-600/20 hover:text-red-400 text-gray-300 text-xs py-2 rounded-lg transition border border-gray-700 hover:border-red-500">
                <i data-lucide="bell-off" class="w-3 h-3"></i> Unsubscribe
              </button>
            </form>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <script>lucide.createIcons();</script>
</body>
</html>