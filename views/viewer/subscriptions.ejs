<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Binge — Subscriptions</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
</head>
<body class="bg-gray-950 text-white min-h-screen flex flex-col">

  <!-- Navbar -->
  <nav class="bg-gray-950 border-b border-gray-800 px-4 py-3 flex items-center gap-4 sticky top-0 z-50 w-full">
    <div class="flex items-center gap-3 w-48 flex-shrink-0">
      <button onclick="toggleSidebar()" class="text-gray-400 hover:text-white p-1.5 rounded-lg hover:bg-gray-800 transition">
        <i data-lucide="menu" class="w-5 h-5"></i>
      </button>
      <a href="/viewer/home" class="text-xl font-bold text-red-500">Binge</a>
    </div>
    <div class="flex-1 flex gap-2 max-w-2xl mx-auto">
      <input type="text" placeholder="Search videos..."
        class="flex-1 bg-gray-900 text-white border border-gray-700 rounded-full px-5 py-2 text-sm focus:outline-none focus:border-red-500 transition"/>
      <button class="bg-gray-800 hover:bg-gray-700 px-5 py-2 rounded-full border border-gray-700 transition">
        <i data-lucide="search" class="w-4 h-4"></i>
      </button>
    </div>
    <div class="w-48 flex-shrink-0 flex justify-end relative">
      <button onclick="toggleProfile()"
        class="flex items-center gap-2 hover:bg-gray-800 px-3 py-1.5 rounded-full transition">
        <div class="w-8 h-8 rounded-full overflow-hidden flex-shrink-0 bg-red-600 flex items-center justify-center font-bold text-sm">
          <% if (user.avatar) { %>
            <img src="/uploads/<%= user.avatar %>" class="w-full h-full object-cover">
          <% } else { %>
            <%= user.firstName.charAt(0).toUpperCase() %>
          <% } %>
        </div>
        <span class="text-white text-sm font-medium hidden sm:block"><%= user.firstName %></span>
        <i data-lucide="chevron-down" class="w-4 h-4 text-gray-400"></i>
      </button>
      <div id="profileDropdown"
        class="hidden absolute top-12 right-0 bg-gray-900 border border-gray-700 rounded-xl shadow-2xl w-56 z-50 overflow-hidden">
        <div class="px-4 py-3 border-b border-gray-700 flex items-center gap-3">
          <div class="w-10 h-10 rounded-full overflow-hidden bg-red-600 flex items-center justify-center font-bold text-sm">
            <% if (user.avatar) { %>
              <img src="/uploads/<%= user.avatar %>" class="w-full h-full object-cover">
            <% } else { %>
              <%= user.firstName.charAt(0).toUpperCase() %>
            <% } %>
          </div>
          <div>
            <p class="text-white text-sm font-semibold"><%= user.firstName %> <%= user.lastName %></p>
            <p class="text-gray-400 text-xs"><%= user.email %></p>
          </div>
        </div>
        <div class="py-1">
          <a href="/viewer/profile"
            class="flex items-center gap-3 px-4 py-2.5 text-gray-300 hover:bg-gray-800 text-sm transition">
            <i data-lucide="user-circle" class="w-4 h-4"></i> My Profile
          </a>
          <a href="/viewer/history"
            class="flex items-center gap-3 px-4 py-2.5 text-gray-300 hover:bg-gray-800 text-sm transition">
            <i data-lucide="history" class="w-4 h-4"></i> Watch History
          </a>
          <a href="/viewer/playlists"
            class="flex items-center gap-3 px-4 py-2.5 text-gray-300 hover:bg-gray-800 text-sm transition">
            <i data-lucide="list-music" class="w-4 h-4"></i> Playlists
          </a>
          <a href="/viewer/subscriptions"
            class="flex items-center gap-3 px-4 py-2.5 text-gray-300 hover:bg-gray-800 text-sm transition">
            <i data-lucide="bell" class="w-4 h-4"></i> Subscriptions
          </a>
          <div class="border-t border-gray-700 my-1"></div>
          <a href="/auth/logout"
            class="flex items-center gap-3 px-4 py-2.5 text-red-400 hover:bg-gray-800 text-sm transition">
            <i data-lucide="log-out" class="w-4 h-4"></i> Sign Out
          </a>
        </div>
      </div>
    </div>
  </nav>

  <div class="flex flex-1 overflow-hidden">

    <!-- Sidebar -->
    <aside id="sidebar" class="w-52 flex-shrink-0 bg-gray-950 border-r border-gray-900 pt-4 pb-10 overflow-y-auto">
      <div class="space-y-1 px-2">
        <a href="/viewer/home" class="flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-gray-800 text-gray-300 hover:text-white text-sm transition">
          <i data-lucide="home" class="w-4 h-4"></i> Home
        </a>
        <a href="/viewer/subscriptions" class="flex items-center gap-3 px-3 py-2.5 rounded-xl bg-gray-800 text-white text-sm font-medium">
          <i data-lucide="bell" class="w-4 h-4"></i> Subscriptions
        </a>
        <a href="/viewer/history" class="flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-gray-800 text-gray-300 hover:text-white text-sm transition">
          <i data-lucide="history" class="w-4 h-4"></i> History
        </a>
        <a href="/viewer/playlists" class="flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-gray-800 text-gray-300 hover:text-white text-sm transition">
          <i data-lucide="list-music" class="w-4 h-4"></i> Playlists
        </a>

        <% if (creators.length > 0) { %>
          <div class="border-t border-gray-800 my-3"></div>
          <p class="text-gray-500 text-xs px-3 mb-2 uppercase tracking-wider">Subscriptions</p>
          <% creators.forEach(c => { %>
            <a href="/viewer/channel/<%= c.Id %>"
               class="flex items-center gap-3 px-3 py-2 rounded-xl hover:bg-gray-800 text-gray-300 hover:text-white text-sm transition">
              <div class="w-6 h-6 rounded-full overflow-hidden bg-red-600 flex items-center justify-center text-xs font-bold flex-shrink-0">
                <% if (c.Avatar) { %>
                  <img src="/uploads/<%= c.Avatar %>" class="w-full h-full object-cover">
                <% } else { %>
                  <%= c.ChannelName.charAt(0).toUpperCase() %>
                <% } %>
              </div>
              <span class="truncate"><%= c.ChannelName %></span>
            </a>
          <% }) %>
        <% } %>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 overflow-y-auto px-6 py-5">

      <!-- Header -->
      <div class="flex items-center gap-3 mb-6">
        <i data-lucide="bell" class="w-6 h-6 text-red-500"></i>
        <h2 class="text-xl font-bold">Subscriptions</h2>
      </div>

      <% if (creators.length === 0) { %>
        <!-- Empty State -->
        <div class="text-center mt-24">
          <div class="w-20 h-20 bg-gray-800 rounded-full flex items-center justify-center mx-auto mb-4">
            <i data-lucide="bell-off" class="w-10 h-10 text-gray-600"></i>
          </div>
          <h3 class="text-xl font-semibold text-gray-300 mb-2">No subscriptions yet</h3>
          <p class="text-gray-500 text-sm mb-6">Subscribe to creators to see their latest videos here</p>
          <a href="/viewer/home" class="inline-flex items-center gap-2 bg-red-600 hover:bg-red-700 text-white px-6 py-2.5 rounded-full text-sm transition">
            <i data-lucide="compass" class="w-4 h-4"></i> Browse Videos
          </a>
        </div>
      <% } else { %>

        <!-- Channels Row -->
        <div class="flex gap-4 mb-8 overflow-x-auto pb-2">
          <% creators.forEach(c => { %>
            <a href="/viewer/channel/<%= c.Id %>" class="flex flex-col items-center gap-2 flex-shrink-0 group">
              <div class="w-16 h-16 rounded-full overflow-hidden bg-red-600 flex items-center justify-center text-xl font-bold ring-2 ring-transparent group-hover:ring-red-500 transition">
                <% if (c.Avatar) { %>
                  <img src="/uploads/<%= c.Avatar %>" class="w-full h-full object-cover">
                <% } else { %>
                  <%= c.ChannelName.charAt(0).toUpperCase() %>
                <% } %>
              </div>
              <span class="text-xs text-gray-400 group-hover:text-white transition text-center w-16 truncate"><%= c.ChannelName %></span>
            </a>
          <% }) %>
        </div>

        <!-- Latest Videos -->
        <% if (videos.length === 0) { %>
          <div class="text-center py-16">
            <i data-lucide="video-off" class="w-12 h-12 text-gray-700 mx-auto mb-3"></i>
            <p class="text-gray-500">No recent videos from your subscriptions</p>
          </div>
        <% } else { %>
          <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4 flex items-center gap-2">
            <i data-lucide="play-circle" class="w-4 h-4"></i> Latest Videos
          </h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-4 gap-y-8">
            <% videos.forEach(video => { %>
              <a href="/viewer/watch/<%= video.Id %>" class="block group cursor-pointer">

                <!-- Thumbnail -->
                <div class="rounded-xl overflow-hidden aspect-video mb-3 relative bg-gray-800">
                  <% if (video.thumbnail) { %>
                    <img src="<%= video.thumbnail %>" alt="<%= video.Title %>"
                         class="w-full h-full object-cover group-hover:brightness-75 transition"
                         onerror="this.style.display='none'">
                  <% } else { %>
                    <div class="w-full h-full flex items-center justify-center">
                      <i data-lucide="play-circle" class="w-14 h-14 text-gray-600"></i>
                    </div>
                  <% } %>
                  <span class="absolute bottom-2 right-2 bg-black/80 text-white text-xs px-1.5 py-0.5 rounded font-medium">
                    <%= Math.floor(video.Duration/60) %>:<%= String(video.Duration%60).padStart(2,'0') %>
                  </span>
                  <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition">
                    <div class="w-12 h-12 bg-red-600/90 rounded-full flex items-center justify-center">
                      <i data-lucide="play" class="w-5 h-5 text-white ml-0.5"></i>
                    </div>
                  </div>
                </div>

                <!-- Info -->
                <div class="flex gap-3">
                  <a href="/viewer/channel/<%= video.CreatorId %>" class="flex-shrink-0 mt-0.5">
                    <div class="w-9 h-9 rounded-full overflow-hidden bg-red-600 flex items-center justify-center font-bold text-sm">
                      <% if (video.CreatorAvatar) { %>
                        <img src="/uploads/<%= video.CreatorAvatar %>" class="w-full h-full object-cover">
                      <% } else { %>
                        <%= video.ChannelName.charAt(0).toUpperCase() %>
                      <% } %>
                    </div>
                  </a>
                  <div class="flex-1 min-w-0">
                    <h3 class="text-white text-sm font-semibold line-clamp-2 leading-snug mb-1 group-hover:text-red-400 transition">
                      <%= video.Title %>
                    </h3>
                    <p class="text-gray-400 text-xs"><%= video.ChannelName %></p>
                    <p class="text-gray-500 text-xs">
                      <%= video.Views.toLocaleString() %> views · <%= new Date(video.UploadDate).toLocaleDateString() %>
                    </p>
                  </div>
                </div>

              </a>
            <% }) %>
          </div>
        <% } %>
      <% } %>
    </main>
  </div>

  <script>
    lucide.createIcons();
    
    function toggleSidebar() {
      document.getElementById('sidebar').classList.toggle('hidden');
    }

    function toggleProfile() {
      document.getElementById('profileDropdown').classList.toggle('hidden');
    }

    document.addEventListener('click', (e) => {
      if (!e.target.closest('.relative') && !e.target.closest('[onclick="toggleProfile()"]')) {
        document.getElementById('profileDropdown').classList.add('hidden');
      }
    });
  </script>
</body>
</html>