<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Binge — <%= video.Title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-950 text-white min-h-screen">

  <!-- Navbar -->
  <nav class="bg-gray-900 border-b border-gray-800 px-6 py-3 flex items-center justify-between sticky top-0 z-50">
    <a href="/viewer/home" class="text-2xl font-bold text-red-500">Binge</a>
    <div class="flex items-center gap-4">
      <span class="text-gray-400 text-sm">Welcome, <span class="text-white font-medium"><%= user.firstName %></span></span>
      <a href="/auth/logout" class="bg-red-600 hover:bg-red-700 text-white text-sm px-4 py-1.5 rounded-lg transition">Logout</a>
    </div>
  </nav>

  <div class="max-w-6xl mx-auto px-6 py-8 grid grid-cols-1 lg:grid-cols-3 gap-8">

    <!-- Left: Video + Info -->
    <div class="lg:col-span-2">

      <!-- Video Player -->
      <div class="bg-black rounded-xl overflow-hidden aspect-video mb-4">
        <iframe
          src="<%= embedUrl %>"
          class="w-full h-full"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen>
        </iframe>
      </div>

      <!-- Title & Stats -->
      <h1 class="text-xl font-bold mb-2"><%= video.Title %></h1>
      <div class="flex items-center justify-between mb-4">
        <div class="flex items-center gap-4 text-gray-400 text-sm">
          <span><%= video.Views.toLocaleString() %> views</span>
          <span><%= new Date(video.UploadDate).toLocaleDateString() %></span>
          <span class="bg-red-600/20 text-red-400 px-2 py-0.5 rounded-full text-xs"><%= video.Category %></span>
        </div>

        <!-- Like Button -->
        <form action="/viewer/like/<%= video.Id %>" method="POST">
          <button type="submit"
            class="flex items-center gap-2 <%= liked ? 'bg-red-600 text-white' : 'bg-gray-800 text-gray-300' %> hover:bg-red-600 hover:text-white px-4 py-2 rounded-lg text-sm transition">
            ❤️ <%= liked ? 'Liked' : 'Like' %> · <%= video.LikeCount %>
          </button>
        </form>
      </div>

      <!-- Channel Info + Subscribe -->
      <div class="bg-gray-900 rounded-xl p-4 flex items-center justify-between mb-6">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-red-600 rounded-full flex items-center justify-center font-bold">
            <%= video.ChannelName.charAt(0).toUpperCase() %>
          </div>
          <div>
            <p class="font-semibold"><%= video.ChannelName %></p>
            <p class="text-gray-400 text-xs"><%= video.TotalSubscribers.toLocaleString() %> subscribers</p>
          </div>
        </div>
        <form action="/viewer/subscribe/<%= video.CreatorId %>" method="POST">
          <button type="submit"
            class="<%= subscribed ? 'bg-gray-700 text-gray-300' : 'bg-red-600 text-white' %> hover:opacity-80 px-4 py-2 rounded-lg text-sm font-semibold transition">
            <%= subscribed ? 'Subscribed ✓' : 'Subscribe' %>
          </button>
        </form>
      </div>

      <!-- Description -->
      <% if (video.Description) { %>
        <div class="bg-gray-900 rounded-xl p-4 mb-6">
          <p class="text-gray-300 text-sm leading-relaxed"><%= video.Description %></p>
        </div>
      <% } %>

      <!-- Comments -->
      <div class="bg-gray-900 rounded-xl p-5">
        <h3 class="font-bold mb-4"><%= comments.length %> Comments</h3>

        <!-- Add Comment -->
        <form action="/viewer/comment/<%= video.Id %>" method="POST" class="mb-6">
          <textarea
            name="content"
            rows="2"
            required
            placeholder="Add a comment..."
            class="w-full bg-gray-800 text-white border border-gray-700 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-red-500 transition resize-none mb-2"
          ></textarea>
          <button type="submit"
            class="bg-red-600 hover:bg-red-700 text-white text-sm px-4 py-2 rounded-lg transition">
            Post Comment
          </button>
        </form>

        <!-- Comments List -->
        <% if (comments.length === 0) { %>
          <p class="text-gray-500 text-sm">No comments yet. Be the first!</p>
        <% } else { %>
          <div class="space-y-4">
            <% comments.forEach(comment => { %>
              <div class="flex gap-3">
                <div class="w-8 h-8 bg-gray-700 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0">
                  <%= comment.FirstName.charAt(0).toUpperCase() %>
                </div>
                <div>
                  <p class="text-sm font-semibold"><%= comment.FirstName %> <%= comment.LastName %>
                    <span class="text-gray-500 font-normal text-xs ml-2">
                      <%= new Date(comment.CommentDate).toLocaleDateString() %>
                    </span>
                  </p>
                  <p class="text-gray-300 text-sm mt-1"><%= comment.Content %></p>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>

    </div>

    <!-- Right: Related Videos -->
    <div>
      <h3 class="font-bold mb-4 text-gray-300">Related Videos</h3>
      <div class="space-y-3">
        <% related.forEach(v => { %>
          <a href="/viewer/watch/<%= v.Id %>" class="flex gap-3 bg-gray-900 rounded-xl p-3 hover:bg-gray-800 transition">
            <div class="w-24 h-16 bg-gray-800 rounded-lg flex items-center justify-center flex-shrink-0 text-2xl">🎬</div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium line-clamp-2"><%= v.Title %></p>
              <p class="text-gray-400 text-xs mt-1"><%= v.ChannelName %></p>
              <p class="text-gray-500 text-xs"><%= v.Views.toLocaleString() %> views</p>
            </div>
          </a>
        <% }) %>
      </div>
    </div>

  </div>

</body>
</html>